generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  state     String?
  zip       String?
  phone     String?
  email     String?
  taxRate   Float    @default(0.0825)
  currency  String   @default("USD")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees         Employee[]
  orders            Order[]
  inventory         Inventory[]
  shifts            Shift[]
  purchaseOrders    PurchaseOrder[]
  workOrders        WorkOrder[]
  posShifts         PosShift[]
  warehouseZones    WarehouseZone[]
  salesQuotes       SalesQuote[]
  productionOrders  ProductionOrder[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   @default("cashier")
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee?
}

model Employee {
  id         String   @id @default(cuid())
  userId     String   @unique
  storeId    String
  firstName  String
  lastName   String
  position   String
  department String?
  hireDate   DateTime @default(now())
  hourlyRate Float?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user           User          @relation(fields: [userId], references: [id])
  store          Store         @relation(fields: [storeId], references: [id])
  shifts         Shift[]
  payrollEntries PayrollEntry[]
  goals          EmployeeGoal[]
}

model Shift {
  id         String   @id @default(cuid())
  employeeId String
  storeId    String
  startTime  DateTime
  endTime    DateTime
  status     String   @default("scheduled")
  notes      String?
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  store    Store    @relation(fields: [storeId], references: [id])
}

model ProductCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  color     String?
  icon      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  parent   ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id           String   @id @default(cuid())
  sku          String   @unique
  barcode      String?  @unique
  name         String
  description  String?
  categoryId   String?
  costPrice    Float    @default(0)
  salePrice    Float    @default(0)
  unit         String   @default("each")
  taxable      Boolean  @default(true)
  trackStock   Boolean  @default(true)
  isActive     Boolean  @default(true)
  imageUrl     String?
  supplierId   String?
  reorderPoint Int?
  reorderQty   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category           ProductCategory?    @relation(fields: [categoryId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  inventory          Inventory[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  wmsBinContents     WmsBinContent[]
  wmsEntries         WmsEntry[]
  attributes         ProductAttributeValue[]
  variantGroup       ProductVariantGroup?
  planningLines      ProjectPlanLine[]
  quoteLines         SalesQuoteLine[]
  serviceItems       ServiceItem[]       @relation("ProductServiceItems")
  // Manufacturing relations
  bomOutputs         ProductionBOM[]     @relation("BOMOutputProduct")
  bomComponents      ProductionBOMLine[] @relation("BOMComponent")
  productionOrders   ProductionOrder[]   @relation("ProductionOrderProduct")
  productionLines    ProductionOrderLine[] @relation("ProductionOrderLineProduct")
  subcontractingLines SubcontractingLine[] @relation("SubcontractingLineProduct")
}

model ProductAttribute {
  id         String   @id @default(cuid())
  name       String   @unique
  attrType   String   @default("text")
  isRequired Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  values     ProductAttributeValue[]
}

model ProductAttributeValue {
  id          String  @id @default(cuid())
  productId   String
  attributeId String
  value       String
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id])
  @@unique([productId, attributeId])
}

model ProductVariantGroup {
  id         String   @id @default(cuid())
  productId  String   @unique
  createdAt  DateTime @default(now())
  dimensions VariantDimension[]
  variants   ProductVariant[]
  product    Product  @relation(fields: [productId], references: [id])
}

model VariantDimension {
  id        String  @id @default(cuid())
  groupId   String
  name      String
  values    String
  sortOrder Int     @default(0)
  group     ProductVariantGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id         String   @id @default(cuid())
  groupId    String
  sku        String   @unique
  barcode    String?
  dimensions String
  costPrice  Float    @default(0)
  salePrice  Float    @default(0)
  stockQty   Float    @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  group      ProductVariantGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Assortment {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("draft")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lines       AssortmentLine[]
  channels    AssortmentChannel[]
}

model AssortmentLine {
  id           String  @id @default(cuid())
  assortmentId String
  productId    String?
  categoryId   String?
  lineType     String  @default("product")
  assortment   Assortment @relation(fields: [assortmentId], references: [id], onDelete: Cascade)
}

model AssortmentChannel {
  id           String  @id @default(cuid())
  assortmentId String
  channelId    String
  assortment   Assortment @relation(fields: [assortmentId], references: [id], onDelete: Cascade)
  @@unique([assortmentId, channelId])
}

model Customer {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String?  @unique
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  loyaltyPoints  Int      @default(0)
  totalSpent     Float    @default(0)
  visitCount     Int      @default(0)
  notes          String?
  tags           String?
  creditLimit    Float    @default(0)
  creditStatus   String   @default("good")  // good | warning | hold
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders             Order[]
  communications     Communication[]
  arInvoices         CustomerInvoice[]
  paymentSettlements CustomerPaymentSettlement[]
  campaignContacts   CampaignContact[]
  workOrders         WorkOrder[]
  loyaltyCard        LoyaltyCard?
  projects           Project[]
  contracts          Contract[]
  salesQuotes        SalesQuote[]
  serviceContracts   ServiceContract[] @relation("CustomerServiceContracts")
  serviceItems       ServiceItem[]     @relation("CustomerServiceItems")
  serviceOrders      ServiceOrder[]    @relation("CustomerServiceOrders")
}

model Order {
  id             String   @id @default(cuid())
  orderNumber    String   @unique
  storeId        String
  customerId     String?
  status         String   @default("pending")
  subtotal       Float    @default(0)
  taxAmount      Float    @default(0)
  discountAmount Float    @default(0)
  totalAmount    Float    @default(0)
  paymentMethod  String?
  amountTendered Float?
  changeDue      Float?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  payments Payment[]

  posShiftId String?
  posShift   PosShift? @relation(fields: [posShiftId], references: [id])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  sku         String
  quantity    Float
  unitPrice   Float
  discount    Float   @default(0)
  taxAmount   Float   @default(0)
  lineTotal   Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        String   @id @default(cuid())
  orderId   String
  method    String
  amount    Float
  reference String?
  status    String   @default("completed")
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Inventory {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  quantity  Float    @default(0)
  reserved  Float    @default(0)
  location  String?
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])

  @@unique([productId, storeId])
}

model InventoryTransaction {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  type      String
  quantity  Float
  beforeQty Float
  afterQty  Float
  reference String?
  notes     String?
  createdBy String?
  createdAt DateTime @default(now())
}

model Supplier {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  zip          String?
  paymentTerms String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products       Product[]
  purchaseOrders PurchaseOrder[]
  contracts      Contract[]
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  poNumber     String    @unique
  supplierId   String
  storeId      String
  status       String    @default("draft")
  subtotal     Float     @default(0)
  taxAmount    Float     @default(0)
  shippingCost Float     @default(0)
  totalAmount  Float     @default(0)
  expectedDate DateTime?
  receivedDate DateTime?
  notes        String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  store     Store                @relation(fields: [storeId], references: [id])
  items     PurchaseOrderItem[]
  receipts  PurchaseReceipt[]
}

model PurchaseOrderItem {
  id          String  @id @default(cuid())
  poId        String
  productId   String
  productName String
  sku         String
  orderedQty  Float
  receivedQty Float   @default(0)
  unitCost    Float
  lineTotal   Float

  purchaseOrder PurchaseOrder        @relation(fields: [poId], references: [id], onDelete: Cascade)
  product       Product               @relation(fields: [productId], references: [id])
  receiptLines  PurchaseReceiptLine[]
}

model ServiceCase {
  id              String         @id @default(cuid())
  caseNumber      String         @unique
  customerId      String?
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  channel         String         @default("email")
  subject         String
  description     String?
  category        String         @default("general")
  priority        String         @default("normal")
  status          String         @default("open")
  assignedTo      String?
  resolvedAt      DateTime?
  firstResponseAt DateTime?
  slaDueAt        DateTime?
  slaBreached     Boolean        @default(false)
  resolutionNotes String?
  satisfaction    Int?
  orderId         String?
  activities      CaseActivity[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model CaseActivity {
  id           String      @id @default(cuid())
  caseId       String
  case         ServiceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  activityType String      @default("note")
  body         String
  authorName   String?
  isInternal   Boolean     @default(false)
  emailSubject String?
  duration     Int?
  createdAt    DateTime    @default(now())
}

model SlaPolicy {
  id                String   @id @default(cuid())
  name              String
  priority          String   @default("normal")
  firstResponseHrs  Int      @default(4)
  resolutionHrs     Int      @default(24)
  businessHoursOnly Boolean  @default(true)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model KnowledgeArticle {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  category     String    @default("general")
  body         String
  summary      String?
  tags         String?
  status       String    @default("draft")
  publishedAt  DateTime?
  viewCount    Int       @default(0)
  helpfulCount Int       @default(0)
  authorName   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ChatSession {
  id            String        @id @default(cuid())
  sessionNumber String        @unique
  customerId    String?
  customerName  String?
  customerEmail String?
  agentName     String?
  status        String        @default("waiting")
  queueId       String?
  waitTime      Int           @default(0)
  duration      Int?
  caseId        String?
  messages      ChatMessage[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderType  String      @default("customer")
  senderName  String?
  body        String
  createdAt   DateTime    @default(now())
}

model ServiceQueue {
  id          String   @id @default(cuid())
  name        String
  queueType   String   @default("cases")
  assignedTo  String   @default("[]")
  maxWaitTime Int      @default(300)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Communication {
  id         String   @id @default(cuid())
  customerId String
  channel    String
  direction  String
  subject    String?
  content    String?
  status     String   @default("sent")
  createdBy  String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  type        String
  status      String    @default("draft")
  subject     String?
  content     String?
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  targetCount Int       @default(0)
  sentCount   Int       @default(0)
  openCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contacts CampaignContact[]
}

model WorkOrder {
  id           String    @id @default(cuid())
  woNumber     String    @unique
  storeId      String
  customerId   String?
  title        String
  description  String?
  status       String    @default("new")
  priority     String    @default("medium")
  assignedTo   String?
  scheduledAt  DateTime?
  completedAt  DateTime?
  estimatedHrs Float?
  actualHrs    Float?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  store    Store           @relation(fields: [storeId], references: [id])
  customer Customer?       @relation(fields: [customerId], references: [id])
  lines    WorkOrderLine[]
}

// ─── General Ledger ───────────────────────────────────────────────────────────

model Account {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  type              String   // asset | liability | equity | revenue | expense
  subtype           String?
  mainAccountType   String?  // BC: balance_sheet | profit_loss (drives year-end behavior)
  openingAccountId  String?  // BC: where balance transfers to on year-end close
  balance           Float    @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  journalLines    JournalLine[]
  bankAccounts    BankAccount[]
  postingDebits   PostingRule[]  @relation("PostingRuleDebit")
  postingCredits  PostingRule[]  @relation("PostingRuleCredit")
  budgetEntries   BudgetEntry[]
  taxCodes        TaxCode[]
}

model JournalEntry {
  id          String   @id @default(cuid())
  reference   String
  description String?
  date        DateTime @default(now())
  status      String   @default("posted")  // posted | reversed
  createdBy   String?
  createdAt   DateTime @default(now())

  lines JournalLine[]
}

model JournalLine {
  id        String  @id @default(cuid())
  entryId   String
  accountId String
  debit     Float   @default(0)
  credit    Float   @default(0)
  memo      String?

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])
}

// ─── Business Central: Vendor / AP ───────────────────────────────────────────

model VendorGroup {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  defaultPayTerms String?  // Net30 | Net60 | COD
  description     String?
  createdAt       DateTime @default(now())

  vendors Vendor[]
}

model Vendor {
  id             String   @id @default(cuid())
  vendorCode     String   @unique
  name           String
  vendorGroupId  String?
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  taxId          String?
  paymentTerms   String?  // Net30 | Net60 | Net15 | COD | Immediate
  paymentMethod  String?  // Check | ACH | Wire | Cash
  currency       String   @default("USD")
  creditLimit    Float?
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendorGroup          VendorGroup?          @relation(fields: [vendorGroupId], references: [id])
  invoices             VendorInvoice[]
  payments             VendorPayment[]
  purchaseOrders       VendorPO[]
  scorecards           VendorScorecard[]
  subcontractingOrders SubcontractingOrder[]
}

model VendorInvoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  vendorId        String
  invoiceDate     DateTime
  dueDate         DateTime
  postingDate     DateTime @default(now())
  subtotal        Float
  taxAmount       Float    @default(0)
  totalAmount     Float
  paidAmount      Float    @default(0)
  status          String   @default("draft")   // draft | posted | matched | paid | partial | cancelled
  matchingStatus  String   @default("none")    // none | two_way | three_way
  poId            String?
  journalEntryId  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor      Vendor                    @relation(fields: [vendorId], references: [id])
  lines       VendorInvoiceLine[]
  settlements VendorPaymentSettlement[]
}

model VendorInvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  accountCode String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  lineAmount  Float
  taxAmount   Float   @default(0)

  invoice VendorInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model VendorPayment {
  id             String   @id @default(cuid())
  paymentNumber  String   @unique
  vendorId       String
  paymentDate    DateTime
  amount         Float
  paymentMethod  String   @default("Check")  // Check | ACH | Wire | Cash
  bankAccountId  String?
  checkNumber    String?
  status         String   @default("draft")  // draft | posted | cleared | voided
  journalEntryId String?
  notes          String?
  createdAt      DateTime @default(now())

  vendor      Vendor                    @relation(fields: [vendorId], references: [id])
  bankAccount BankAccount?              @relation(fields: [bankAccountId], references: [id])
  settlements VendorPaymentSettlement[]
}

model VendorPaymentSettlement {
  id            String   @id @default(cuid())
  paymentId     String
  invoiceId     String
  settledAmount Float
  discountTaken Float    @default(0)
  settledAt     DateTime @default(now())

  payment VendorPayment @relation(fields: [paymentId], references: [id])
  invoice VendorInvoice @relation(fields: [invoiceId], references: [id])
}

// ─── Business Central: Customer / AR ─────────────────────────────────────────

model CustomerInvoice {
  id             String   @id @default(cuid())
  invoiceNumber  String   @unique
  customerId     String
  orderId        String?
  invoiceDate    DateTime
  dueDate        DateTime
  postingDate    DateTime @default(now())
  subtotal       Float
  taxAmount      Float    @default(0)
  totalAmount    Float
  paidAmount     Float    @default(0)
  status         String   @default("draft")  // draft | posted | paid | partial | cancelled
  invoiceType    String   @default("sales")  // sales | free_text
  journalEntryId String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer    Customer                    @relation(fields: [customerId], references: [id])
  lines       CustomerInvoiceLine[]
  settlements CustomerPaymentSettlement[]
}

model CustomerInvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  accountCode String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  lineAmount  Float
  taxAmount   Float   @default(0)

  invoice CustomerInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model CustomerPaymentSettlement {
  id            String   @id @default(cuid())
  customerId    String
  invoiceId     String
  paymentRef    String?
  settledAmount Float
  discountTaken Float    @default(0)
  settledAt     DateTime @default(now())

  customer Customer        @relation(fields: [customerId], references: [id])
  invoice  CustomerInvoice @relation(fields: [invoiceId], references: [id])
}

// ─── Business Central: Bank & Cash Management ─────────────────────────────────

model BankAccount {
  id             String   @id @default(cuid())
  accountCode    String   @unique
  bankName       String
  accountNumber  String
  accountType    String   @default("checking")  // checking | savings
  currency       String   @default("USD")
  currentBalance Float    @default(0)
  glAccountId    String?
  isActive       Boolean  @default(true)
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  glAccount      Account?          @relation(fields: [glAccountId], references: [id])
  statements     BankStatement[]
  vendorPayments VendorPayment[]
}

model BankStatement {
  id             String   @id @default(cuid())
  bankAccountId  String
  statementDate  DateTime
  openingBalance Float
  closingBalance Float
  status         String   @default("pending")  // pending | in_progress | reconciled
  importedAt     DateTime @default(now())
  reconciledAt   DateTime?

  bankAccount BankAccount         @relation(fields: [bankAccountId], references: [id])
  lines       BankStatementLine[]
}

model BankStatementLine {
  id              String   @id @default(cuid())
  statementId     String
  transactionDate DateTime
  description     String
  amount          Float
  transactionType String   @default("deposit")  // deposit | withdrawal | fee | interest
  reference       String?
  matchingStatus  String   @default("unmatched")  // unmatched | matched | manual
  matchedToId     String?
  createdAt       DateTime @default(now())

  statement BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
}

// ─── Business Central: Fiscal Calendar & Year-End Close ──────────────────────

model FiscalYear {
  id         String   @id @default(cuid())
  name       String   @unique  // e.g., FY2026
  startDate  DateTime
  endDate    DateTime
  status     String   @default("open")  // open | closing | closed | archived
  closedAt   DateTime?
  closedBy   String?
  createdAt  DateTime @default(now())

  periods      FiscalPeriod[]
  yearEndClose YearEndClose?
}

model FiscalPeriod {
  id           String   @id @default(cuid())
  fiscalYearId String
  periodNumber Int
  name         String
  startDate    DateTime
  endDate      DateTime
  status       String   @default("open")  // open | closed | on_hold
  closedAt     DateTime?

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id])

  @@unique([fiscalYearId, periodNumber])
}

model YearEndClose {
  id                        String   @id @default(cuid())
  fiscalYearId              String   @unique
  closingDate               DateTime
  status                    String   @default("pending")  // pending | in_progress | completed | reversed
  retainedEarningsAccountId String?
  openingVoucherId          String?
  closingVoucherId          String?
  totalRevenue              Float    @default(0)
  totalExpenses             Float    @default(0)
  netIncome                 Float    @default(0)
  completedAt               DateTime?
  completedBy               String?
  notes                     String?
  createdAt                 DateTime @default(now())

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id])
}

