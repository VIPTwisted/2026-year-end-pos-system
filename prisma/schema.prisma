generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  state     String?
  zip       String?
  phone     String?
  email     String?
  taxRate   Float    @default(0.0825)
  currency  String   @default("USD")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees      Employee[]
  orders         Order[]
  inventory      Inventory[]
  shifts         Shift[]
  purchaseOrders PurchaseOrder[]
  workOrders     WorkOrder[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   @default("cashier")
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee?
}

model Employee {
  id         String   @id @default(cuid())
  userId     String   @unique
  storeId    String
  firstName  String
  lastName   String
  position   String
  department String?
  hireDate   DateTime @default(now())
  hourlyRate Float?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User      @relation(fields: [userId], references: [id])
  store  Store     @relation(fields: [storeId], references: [id])
  shifts Shift[]
}

model Shift {
  id         String   @id @default(cuid())
  employeeId String
  storeId    String
  startTime  DateTime
  endTime    DateTime
  status     String   @default("scheduled")
  notes      String?
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  store    Store    @relation(fields: [storeId], references: [id])
}

model ProductCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  color     String?
  icon      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  parent   ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id           String   @id @default(cuid())
  sku          String   @unique
  barcode      String?  @unique
  name         String
  description  String?
  categoryId   String?
  costPrice    Float    @default(0)
  salePrice    Float    @default(0)
  unit         String   @default("each")
  taxable      Boolean  @default(true)
  trackStock   Boolean  @default(true)
  isActive     Boolean  @default(true)
  imageUrl     String?
  supplierId   String?
  reorderPoint Int?
  reorderQty   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category           ProductCategory?    @relation(fields: [categoryId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  inventory          Inventory[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  wmsBinContents     WmsBinContent[]
  wmsEntries         WmsEntry[]
}

model Customer {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String?  @unique
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  loyaltyPoints  Int      @default(0)
  totalSpent     Float    @default(0)
  visitCount     Int      @default(0)
  notes          String?
  tags           String?
  creditLimit    Float    @default(0)
  creditStatus   String   @default("good")  // good | warning | hold
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders           Order[]
  cases            ServiceCase[]
  communications   Communication[]
  arInvoices       CustomerInvoice[]
  paymentSettlements CustomerPaymentSettlement[]
}

model Order {
  id             String   @id @default(cuid())
  orderNumber    String   @unique
  storeId        String
  customerId     String?
  status         String   @default("pending")
  subtotal       Float    @default(0)
  taxAmount      Float    @default(0)
  discountAmount Float    @default(0)
  totalAmount    Float    @default(0)
  paymentMethod  String?
  amountTendered Float?
  changeDue      Float?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  payments Payment[]
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  sku         String
  quantity    Float
  unitPrice   Float
  discount    Float   @default(0)
  taxAmount   Float   @default(0)
  lineTotal   Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        String   @id @default(cuid())
  orderId   String
  method    String
  amount    Float
  reference String?
  status    String   @default("completed")
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Inventory {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  quantity  Float    @default(0)
  reserved  Float    @default(0)
  location  String?
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])

  @@unique([productId, storeId])
}

model InventoryTransaction {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  type      String
  quantity  Float
  beforeQty Float
  afterQty  Float
  reference String?
  notes     String?
  createdBy String?
  createdAt DateTime @default(now())
}

model Supplier {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  zip          String?
  paymentTerms String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products       Product[]
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  poNumber     String    @unique
  supplierId   String
  storeId      String
  status       String    @default("draft")
  subtotal     Float     @default(0)
  taxAmount    Float     @default(0)
  shippingCost Float     @default(0)
  totalAmount  Float     @default(0)
  expectedDate DateTime?
  receivedDate DateTime?
  notes        String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier Supplier           @relation(fields: [supplierId], references: [id])
  store    Store               @relation(fields: [storeId], references: [id])
  items    PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id          String  @id @default(cuid())
  poId        String
  productId   String
  productName String
  sku         String
  orderedQty  Float
  receivedQty Float   @default(0)
  unitCost    Float
  lineTotal   Float

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product       Product        @relation(fields: [productId], references: [id])
}

model ServiceCase {
  id          String    @id @default(cuid())
  caseNumber  String    @unique
  customerId  String
  subject     String
  description String?
  status      String    @default("open")
  priority    String    @default("medium")
  category    String?
  assignedTo  String?
  resolvedAt  DateTime?
  slaBreached Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer Customer   @relation(fields: [customerId], references: [id])
  notes    CaseNote[]
}

model CaseNote {
  id        String   @id @default(cuid())
  caseId    String
  authorId  String?
  content   String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  case ServiceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model Communication {
  id         String   @id @default(cuid())
  customerId String
  channel    String
  direction  String
  subject    String?
  content    String?
  status     String   @default("sent")
  createdBy  String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  type        String
  status      String    @default("draft")
  subject     String?
  content     String?
  startDate   DateTime?
  endDate     DateTime?
  targetCount Int       @default(0)
  sentCount   Int       @default(0)
  openCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WorkOrder {
  id           String    @id @default(cuid())
  woNumber     String    @unique
  storeId      String
  customerId   String?
  title        String
  description  String?
  status       String    @default("new")
  priority     String    @default("medium")
  assignedTo   String?
  scheduledAt  DateTime?
  completedAt  DateTime?
  estimatedHrs Float?
  actualHrs    Float?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id])
}

// ─── General Ledger ───────────────────────────────────────────────────────────

model Account {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  type              String   // asset | liability | equity | revenue | expense
  subtype           String?
  mainAccountType   String?  // BC: balance_sheet | profit_loss (drives year-end behavior)
  openingAccountId  String?  // BC: where balance transfers to on year-end close
  balance           Float    @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  journalLines    JournalLine[]
  bankAccounts    BankAccount[]
  postingDebits   PostingRule[]  @relation("PostingRuleDebit")
  postingCredits  PostingRule[]  @relation("PostingRuleCredit")
}

model JournalEntry {
  id          String   @id @default(cuid())
  reference   String
  description String?
  date        DateTime @default(now())
  status      String   @default("posted")  // posted | reversed
  createdBy   String?
  createdAt   DateTime @default(now())

  lines JournalLine[]
}

model JournalLine {
  id        String  @id @default(cuid())
  entryId   String
  accountId String
  debit     Float   @default(0)
  credit    Float   @default(0)
  memo      String?

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])
}

// ─── Business Central: Vendor / AP ───────────────────────────────────────────

model VendorGroup {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  defaultPayTerms String?  // Net30 | Net60 | COD
  description     String?
  createdAt       DateTime @default(now())

  vendors Vendor[]
}

model Vendor {
  id             String   @id @default(cuid())
  vendorCode     String   @unique
  name           String
  vendorGroupId  String?
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  taxId          String?
  paymentTerms   String?  // Net30 | Net60 | Net15 | COD | Immediate
  paymentMethod  String?  // Check | ACH | Wire | Cash
  currency       String   @default("USD")
  creditLimit    Float?
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendorGroup     VendorGroup?           @relation(fields: [vendorGroupId], references: [id])
  invoices        VendorInvoice[]
  payments        VendorPayment[]
}

model VendorInvoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  vendorId        String
  invoiceDate     DateTime
  dueDate         DateTime
  postingDate     DateTime @default(now())
  subtotal        Float
  taxAmount       Float    @default(0)
  totalAmount     Float
  paidAmount      Float    @default(0)
  status          String   @default("draft")   // draft | posted | matched | paid | partial | cancelled
  matchingStatus  String   @default("none")    // none | two_way | three_way
  poId            String?
  journalEntryId  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor      Vendor                    @relation(fields: [vendorId], references: [id])
  lines       VendorInvoiceLine[]
  settlements VendorPaymentSettlement[]
}

model VendorInvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  accountCode String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  lineAmount  Float
  taxAmount   Float   @default(0)

  invoice VendorInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model VendorPayment {
  id             String   @id @default(cuid())
  paymentNumber  String   @unique
  vendorId       String
  paymentDate    DateTime
  amount         Float
  paymentMethod  String   @default("Check")  // Check | ACH | Wire | Cash
  bankAccountId  String?
  checkNumber    String?
  status         String   @default("draft")  // draft | posted | cleared | voided
  journalEntryId String?
  notes          String?
  createdAt      DateTime @default(now())

  vendor      Vendor                    @relation(fields: [vendorId], references: [id])
  bankAccount BankAccount?              @relation(fields: [bankAccountId], references: [id])
  settlements VendorPaymentSettlement[]
}

model VendorPaymentSettlement {
  id            String   @id @default(cuid())
  paymentId     String
  invoiceId     String
  settledAmount Float
  discountTaken Float    @default(0)
  settledAt     DateTime @default(now())

  payment VendorPayment @relation(fields: [paymentId], references: [id])
  invoice VendorInvoice @relation(fields: [invoiceId], references: [id])
}

// ─── Business Central: Customer / AR ─────────────────────────────────────────

model CustomerInvoice {
  id             String   @id @default(cuid())
  invoiceNumber  String   @unique
  customerId     String
  orderId        String?
  invoiceDate    DateTime
  dueDate        DateTime
  postingDate    DateTime @default(now())
  subtotal       Float
  taxAmount      Float    @default(0)
  totalAmount    Float
  paidAmount     Float    @default(0)
  status         String   @default("draft")  // draft | posted | paid | partial | cancelled
  invoiceType    String   @default("sales")  // sales | free_text
  journalEntryId String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer    Customer                    @relation(fields: [customerId], references: [id])
  lines       CustomerInvoiceLine[]
  settlements CustomerPaymentSettlement[]
}

model CustomerInvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  accountCode String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  lineAmount  Float
  taxAmount   Float   @default(0)

  invoice CustomerInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model CustomerPaymentSettlement {
  id            String   @id @default(cuid())
  customerId    String
  invoiceId     String
  paymentRef    String?
  settledAmount Float
  discountTaken Float    @default(0)
  settledAt     DateTime @default(now())

  customer Customer        @relation(fields: [customerId], references: [id])
  invoice  CustomerInvoice @relation(fields: [invoiceId], references: [id])
}

// ─── Business Central: Bank & Cash Management ─────────────────────────────────

model BankAccount {
  id             String   @id @default(cuid())
  accountCode    String   @unique
  bankName       String
  accountNumber  String
  accountType    String   @default("checking")  // checking | savings
  currency       String   @default("USD")
  currentBalance Float    @default(0)
  glAccountId    String?
  isActive       Boolean  @default(true)
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  glAccount      Account?          @relation(fields: [glAccountId], references: [id])
  statements     BankStatement[]
  vendorPayments VendorPayment[]
}

model BankStatement {
  id             String   @id @default(cuid())
  bankAccountId  String
  statementDate  DateTime
  openingBalance Float
  closingBalance Float
  status         String   @default("pending")  // pending | in_progress | reconciled
  importedAt     DateTime @default(now())
  reconciledAt   DateTime?

  bankAccount BankAccount         @relation(fields: [bankAccountId], references: [id])
  lines       BankStatementLine[]
}

model BankStatementLine {
  id              String   @id @default(cuid())
  statementId     String
  transactionDate DateTime
  description     String
  amount          Float
  transactionType String   @default("deposit")  // deposit | withdrawal | fee | interest
  reference       String?
  matchingStatus  String   @default("unmatched")  // unmatched | matched | manual
  matchedToId     String?
  createdAt       DateTime @default(now())

  statement BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
}

// ─── Business Central: Fiscal Calendar & Year-End Close ──────────────────────

model FiscalYear {
  id         String   @id @default(cuid())
  name       String   @unique  // e.g., FY2026
  startDate  DateTime
  endDate    DateTime
  status     String   @default("open")  // open | closing | closed | archived
  closedAt   DateTime?
  closedBy   String?
  createdAt  DateTime @default(now())

  periods      FiscalPeriod[]
  yearEndClose YearEndClose?
}

model FiscalPeriod {
  id           String   @id @default(cuid())
  fiscalYearId String
  periodNumber Int
  name         String
  startDate    DateTime
  endDate      DateTime
  status       String   @default("open")  // open | closed | on_hold
  closedAt     DateTime?

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id])

  @@unique([fiscalYearId, periodNumber])
}

model YearEndClose {
  id                        String   @id @default(cuid())
  fiscalYearId              String   @unique
  closingDate               DateTime
  status                    String   @default("pending")  // pending | in_progress | completed | reversed
  retainedEarningsAccountId String?
  openingVoucherId          String?
  closingVoucherId          String?
  totalRevenue              Float    @default(0)
  totalExpenses             Float    @default(0)
  netIncome                 Float    @default(0)
  completedAt               DateTime?
  completedBy               String?
  notes                     String?
  createdAt                 DateTime @default(now())

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id])
}

// ─── Business Central: Posting Profiles ──────────────────────────────────────

model PostingProfile {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  module      String   // AP | AR | INVENTORY | BANK | PAYROLL
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  rules PostingRule[]
}

model PostingRule {
  id              String  @id @default(cuid())
  profileId       String
  transactionType String  // VendorInvoice | CustomerInvoice | VendorPayment | CustomerPayment | Inventory | etc.
  debitAccountId  String?
  creditAccountId String?
  applicableTo    String? // ALL | group code

  profile       PostingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  debitAccount  Account?       @relation("PostingRuleDebit", fields: [debitAccountId], references: [id])
  creditAccount Account?       @relation("PostingRuleCredit", fields: [creditAccountId], references: [id])
}

// ─── Warehouse Management System ─────────────────────────────────────────────

model WmsLocation {
  id              String   @id @default(cuid())
  locationCode    String   @unique
  name            String
  address         String?
  city            String?
  state           String?
  requireReceive  Boolean  @default(false)
  requireShipment Boolean  @default(false)
  requirePick     Boolean  @default(false)
  requirePutaway  Boolean  @default(false)
  binMandatory    Boolean  @default(true)
  isCrossDock     Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  zones            WmsZone[]
  warehouseEntries WmsEntry[]
}

model WmsZone {
  id           String   @id @default(cuid())
  locationCode String
  zoneCode     String
  name         String
  zoneType     String   @default("STORAGE")
  layoutLeft   Float?
  layoutTop    Float?
  layoutWidth  Float?
  layoutHeight Float?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  location WmsLocation @relation(fields: [locationCode], references: [locationCode])
  racks    WmsRack[]

  @@unique([locationCode, zoneCode])
}

model WmsRack {
  id           String   @id @default(cuid())
  locationCode String
  zoneCode     String
  rackCode     String
  name         String?
  sections     Int      @default(1)
  levels       Int      @default(1)
  depth        Int      @default(1)
  binPrefix    String?
  binSeparator String   @default("-")
  reverseDir   Boolean  @default(false)
  digitCount   Int      @default(2)
  createdAt    DateTime @default(now())

  zone WmsZone @relation(fields: [locationCode, zoneCode], references: [locationCode, zoneCode])
  bins WmsBin[]

  @@unique([locationCode, zoneCode, rackCode])
}

model WmsBin {
  id           String   @id @default(cuid())
  locationCode String
  zoneCode     String
  rackCode     String?
  binCode      String
  description  String?
  binType      String   @default("STORAGE")
  maxVolume    Float?
  maxWeight    Float?
  isEmpty      Boolean  @default(true)
  isBlocked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rack     WmsRack?        @relation(fields: [locationCode, zoneCode, rackCode], references: [locationCode, zoneCode, rackCode])
  contents WmsBinContent[]

  @@unique([locationCode, zoneCode, binCode])
}

model WmsBinContent {
  id            String   @id @default(cuid())
  locationCode  String
  zoneCode      String
  binCode       String
  productId     String
  lotNumber     String?
  serialNumber  String?
  quantity      Float    @default(0)
  pickQty       Float    @default(0)
  putawayQty    Float    @default(0)
  posAdjmtQty   Float    @default(0)
  negAdjmtQty   Float    @default(0)
  state         String   @default("AVAILABLE")
  unitOfMeasure String   @default("each")
  updatedAt     DateTime @updatedAt

  bin     WmsBin  @relation(fields: [locationCode, zoneCode, binCode], references: [locationCode, zoneCode, binCode])
  product Product @relation(fields: [productId], references: [id])

  @@unique([locationCode, zoneCode, binCode, productId, lotNumber, serialNumber])
}

model WmsEntry {
  id             String   @id @default(cuid())
  entryNumber    String   @unique
  locationCode   String
  productId      String
  entryType      String
  fromBinCode    String?
  toBinCode      String?
  fromZoneCode   String?
  toZoneCode     String?
  quantity       Float
  lotNumber      String?
  serialNumber   String?
  referenceType  String?
  referenceId    String?
  truckNumber    String?
  shipmentNumber String?
  notes          String?
  postedBy       String?
  postedAt       DateTime @default(now())

  location WmsLocation @relation(fields: [locationCode], references: [locationCode])
  product  Product     @relation(fields: [productId], references: [id])
}

model FamilyCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  parentCode  String?
  createdAt   DateTime @default(now())

  parent   FamilyCategory?  @relation("FamilyCategoryTree", fields: [parentCode], references: [code])
  children FamilyCategory[] @relation("FamilyCategoryTree")
}
