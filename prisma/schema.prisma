  bin     WmsBin  @relation(fields: [locationCode, zoneCode, binCode], references: [locationCode, zoneCode, binCode])
  product Product @relation(fields: [productId], references: [id])

  @@unique([locationCode, zoneCode, binCode, productId, lotNumber, serialNumber])
}

model WmsEntry {
  id             String   @id @default(cuid())
