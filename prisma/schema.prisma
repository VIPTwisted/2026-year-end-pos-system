model Reminder {
  id             String    @id @default(cuid())
  reminderNo     String    @unique @default(cuid())
  customerId     String?
  customerNo     String?
  customerName   String?
  reminderLevel  Int       @default(1)
  postingDate    DateTime  @default(now())
  dueDate        DateTime?
  amountLCY      Float     @default(0)
  reminderFee    Float     @default(0)
  status         String    @default("Open") // Open | Issued | Canceled
  issuedAt       DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lines          ReminderLine[]
}

model ReminderLine {
  id              String   @id @default(cuid())
  reminderId      String
  lineNo          Int
  documentType    String?  // Invoice | Credit Memo
  documentNo      String?
  postingDate     DateTime?
  dueDate         DateTime?
  originalAmount  Float    @default(0)
  remainingAmount Float    @default(0)
  interestAmount  Float    @default(0)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reminder        Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
}

model FinanceChargeMemo {
  id           String    @id @default(cuid())
  memoNo       String    @unique @default(cuid())
  customerId   String?
  customerName String?
  postingDate  DateTime  @default(now())
  dueDate      DateTime?
  amount       Float     @default(0)
  interestRate Float     @default(0)
  status       String    @default("Open") // Open | Issued | Canceled
  issuedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── MODULE: Year-End Closing Entries ────────────────────────────────────────

model ClosingEntry {
  id              String    @id @default(cuid())
  fiscalYearId    String?
  fiscalYear      String
  accountNo       String
  accountName     String?
  closingAmount   Float     @default(0)
  retainedEarningsAccountNo String?
  status          String    @default("ready") // ready | posted
  postedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── MODULE: VAT Statement Lines ─────────────────────────────────────────────

model VatStatementLine {
  id           String  @id @default(cuid())
  statementName String @default("Default")
  rowNo        String
  description  String?
  rowType      String  @default("AccountTotaling") // AccountTotaling | RowTotaling | Description
  amountType   String  @default("Amount")          // Amount | BaseAmount | Unrealized
  accountFilter String?
  calculatedAmount Float @default(0)
  printOnPage  Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Administration Models ───────────────────────────────────────────────────

model CompanyInfo {
  id            String   @id @default("singleton")
  name          String?
  address       String?
  city          String?
  postCode      String?
  country       String?
  phone         String?
  email         String?
  vatNo         String?
  taxRegNo      String?
  iban          String?
  swift         String?
  bankAccountNo String?
  giroNo        String?
  logoUrl       String?
  updatedAt     DateTime @updatedAt
}

model AdminPermissionSet {
  id          String            @id @default(cuid())
  roleId      String            @unique
  name        String
  setType     String            @default("User-Defined")
  permissions AdminPermission[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model AdminPermission {
  id         String             @id @default(cuid())
  permSetId  String
  permSet    AdminPermissionSet @relation(fields: [permSetId], references: [id], onDelete: Cascade)
  objectType String
  objectId   String?
  objectName String?
  canRead    Boolean            @default(false)
  canInsert  Boolean            @default(false)
  canModify  Boolean            @default(false)
  canDelete  Boolean            @default(false)
  canExecute Boolean            @default(false)
  createdAt  DateTime           @default(now())
}

model AdminWorkflow {
  id          String              @id @default(cuid())
  code        String              @unique
  description String
  category    String?
  enabled     Boolean             @default(false)
  steps       AdminWorkflowStep[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model AdminWorkflowStep {
  id                String        @id @default(cuid())
  workflowId        String
  workflow          AdminWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepNo            Int
  event             String
  response          String?
  approverType      String?
  approverLimitType String?
  dueDateFormula    String?
  createdAt         DateTime      @default(now())
}

model AdminChangeLog {
  id           String   @id @default(cuid())
  tableCaption String
  fieldName    String
  oldValue     String?
  newValue     String?
  documentNo   String?
  userId       String?
  userName     String?
  createdAt    DateTime @default(now())
}

// ─── MODULE: Service Management (BC-style) ───────────────────────────────────

model ServiceLoaner {
  id                String    @id @default(cuid())
  loanerNo          String    @unique
  description       String
  itemNo            String?
  serialNo          String?
  status            String    @default("Available")
  lentToCustomerId  String?
  dateLent          DateTime?
  dateReturned      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model FaultCode {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  createdAt   DateTime @default(now())
}

model ResolutionCode {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  createdAt   DateTime @default(now())
}

// ─── MODULE: Inventory Ledger (BC-style) ──────────────────────────────────────

model ValueEntry {
  id                  String   @id @default(cuid())
  entryNo             Int      @default(0)
  postingDate         DateTime @default(now())
  itemId              String?
  itemNo              String?
  entryType           String   @default("Direct Cost")
  itemLedgerEntryType String   @default("Purchase")
  valuedQty           Float    @default(0)
  costAmountActual    Float    @default(0)
  costAmountExpected  Float    @default(0)
  invoiceNo           String?
  documentNo          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ItemVariant {
  id          String   @id @default(cuid())
  itemId      String
  variantCode String
  description String?
  salesPrice  Float    @default(0)
  inventory   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([itemId, variantCode])
}

model ItemAttribute {
  id            String   @id @default(cuid())
  name          String   @unique
  attributeType String   @default("Text")
  unitOfMeasure String?
  blocked       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model StockkepingUnit {
  id           String   @id @default(cuid())
  itemId       String
  variantCode  String?
  locationCode String
  reorderPoint Float    @default(0)
  reorderQty   Float    @default(0)
  safetyStock  Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── MODULE: G/L Register ────────────────────────────────────────────────────

model GlRegister {
  id           String   @id @default(cuid())
  registerNo   Int      @unique @default(autoincrement())
  creationDate DateTime @default(now())
  sourceCode   String   @default("GENJNL")
  userId       String?
  fromEntryNo  Int      @default(0)
  toEntryNo    Int      @default(0)
  journalBatch String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── MODULE: Journal Template ────────────────────────────────────────────────

model JournalTemplate {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String?
  templateType   String   @default("General") // General | Sales | Purchases | Payment | CashReceipt | Assets | Intercompany
  balAccountType String   @default("G/L Account")
  balAccountNo   String?
  noSeries       String?
  recurring      Boolean  @default(false)
  sourceCode     String?
  reasonCode     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
