  bins WmsBin[]

  @@unique([locationCode, zoneCode, rackCode])
}

model WmsBin {
  id           String   @id @default(cuid())
  locationCode String
  zoneCode     String
  rackCode     String?
  binCode      String
  description  String?
  binType      String   @default("STORAGE")
