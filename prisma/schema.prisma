generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  state     String?
  zip       String?
  phone     String?
  email     String?
  taxRate   Float    @default(0.0825)
  currency  String   @default("USD")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees             Employee[]
  orders                Order[]
  inventory             Inventory[]
  shifts                Shift[]
  purchaseOrders        PurchaseOrder[]
  workOrders            WorkOrder[]
  posShifts             PosShift[]
  warehouseZones        WarehouseZone[]
  warehouseBins         WarehouseBin[]
  warehouseReceipts     WarehouseReceipt[]
  warehouseShipments    WarehouseShipment[]
  warehousePicks        WarehousePick[]
  warehousePutAways     WarehousePutAway[]
  warehouseMovements    WarehouseMovement[]
  warehouseInternalPicks WarehouseInternalPick[]
  salesQuotes           SalesQuote[]
  productionOrders      ProductionOrder[]
  generalJournals       GeneralJournal[]
  shopifyStores         ShopifyStore[]
  storeCommerceDevices  StoreCommerceDevice[]
  networkPrinters       NetworkPrinter[]
  transfersFrom         TransferOrder[]        @relation("TransferFromStore")
  transfersTo           TransferOrder[]        @relation("TransferToStore")
}

model ShopifyStore {
  id              String   @id @default(cuid())
  storeId         String?
  shopDomain      String   @unique
  accessToken     String?
  storefrontToken String?
  webhookSecret   String?
  syncProducts    Boolean  @default(true)
  syncCustomers   Boolean  @default(true)
  syncOrders      Boolean  @default(true)
  syncInventory   Boolean  @default(true)
  lastSyncAt      DateTime?
  status          String   @default("disconnected")
  errorMessage    String?
  productCount    Int      @default(0)
  customerCount   Int      @default(0)
  orderCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  store           Store?   @relation(fields: [storeId], references: [id])
  syncLogs        ShopifySyncLog[]
}

model ShopifySyncLog {
  id             String   @id @default(cuid())
  shopifyStoreId String
  syncType       String
  status         String
  recordsSync    Int      @default(0)
  errorMsg       String?
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  shopifyStore   ShopifyStore @relation(fields: [shopifyStoreId], references: [id], onDelete: Cascade)
}

model StoreCommerceDevice {
  id               String   @id @default(cuid())
  deviceId         String   @unique
  deviceName       String
  deviceType       String   @default("StoreCommerce")
  storeId          String?
  registerId       String?
  activationStatus String   @default("inactive")
  activationCode   String?
  cloudPOSUrl      String?
  hardwareProfileId String?
  offlineEnabled   Boolean  @default(false)
  lastSeenAt       DateTime?
  appVersion       String?
  osInfo           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  store            Store?   @relation(fields: [storeId], references: [id])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   @default("cashier")
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee?
}

model Employee {
  id         String   @id @default(cuid())
  userId     String   @unique
  storeId    String
  firstName  String
  lastName   String
  position   String
  department String?
  hireDate   DateTime @default(now())
  hourlyRate Float?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user           User          @relation(fields: [userId], references: [id])
  store          Store         @relation(fields: [storeId], references: [id])
  shifts         Shift[]
  payrollEntries PayrollEntry[]
  goals          EmployeeGoal[]
  selfServiceRequests    SelfServiceRequest[]
  accrualEnrollments     LeaveAccrualEnrollment[]
  questionnaireResponses QuestionnaireResponse[]
  lifeEvents             LifeEvent[]
  fmlaRequests           FMLARequest[]
  i9Verification         I9Verification?
  garnishments           Garnishment[]
  performanceGoals       PerformanceGoal[]
}

// ─── MODULE: Life Events ────────────────────────────────────────────────────

model LifeEvent {
  id            String   @id @default(cuid())
  employeeId    String
  eventType     String   // marriage | divorce | birth | adoption | death | address_change | spouse_job_loss
  eventDate     DateTime
  status        String   @default("pending") // pending | in_review | approved | processed | expired
  documentation String?
  changesJson   String?
  processedBy   String?
  processedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id])
}

// ─── MODULE: FMLA Requests ──────────────────────────────────────────────────

model FMLARequest {
  id               String   @id @default(cuid())
  employeeId       String
  requestType      String   @default("continuous") // continuous | intermittent | reduced_schedule
  fmlaReason       String   // serious_health | family_member | military | birth_adoption
  startDate        DateTime
  endDate          DateTime?
  hoursApproved    Float?
  hoursUsed        Float    @default(0)
  status           String   @default("pending") // pending | approved | denied | active | exhausted | closed
  certificationDue DateTime?
  certReceived     Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  employee         Employee @relation(fields: [employeeId], references: [id])
}

// ─── MODULE: I-9 Verification ───────────────────────────────────────────────

model I9Verification {
  id             String   @id @default(cuid())
  employeeId     String   @unique
  hireDate       DateTime
  section1Date   DateTime?
  section2Date   DateTime?
  reVerifyDate   DateTime?
  listADoc       String?
  listBDoc       String?
  listCDoc       String?
  status         String   @default("pending") // pending | complete | reverify_needed | expired
  expirationDate DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  employee       Employee @relation(fields: [employeeId], references: [id])
}

// ─── MODULE: Garnishments ───────────────────────────────────────────────────

model Garnishment {
  id           String   @id @default(cuid())
  employeeId   String
  caseNumber   String?
  garnishType  String   // child_support | alimony | tax_levy | creditor | student_loan
  issuingState String?
  agency       String?
  amount       Float    @default(0)
  amountType   String   @default("fixed") // fixed | percent
  maxPercent   Float?
  startDate    DateTime
  endDate      DateTime?
  status       String   @default("active") // active | suspended | completed
  totalPaid    Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  employee     Employee @relation(fields: [employeeId], references: [id])
}

// ─── MODULE: Performance Goals ──────────────────────────────────────────────

model PerformanceGoal {
  id            String   @id @default(cuid())
  employeeId    String
  title         String
  description   String?
  category      String   @default("individual") // individual | team | company
  status        String   @default("active") // draft | active | completed | cancelled
  targetDate    DateTime?
  completedAt   DateTime?
  progressPct   Int      @default(0)
  priority      String   @default("medium") // low | medium | high
  reviewCycleId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id])
}

model SelfServiceRequest {
  id            String    @id @default(cuid())
  employeeId    String
  requestType   String
  status        String    @default("pending")
  details       String?
  attachmentUrl String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id])
}

model LeaveAccrualPlan {
  id                String    @id @default(cuid())
  name              String
  leaveTypeId       String?
  accrualFrequency  String    @default("monthly")
  accrualAmount     Float     @default(0)
  maxBalance        Float?
  carryOverLimit    Float?
  waitingPeriodDays Int       @default(0)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  enrollments       LeaveAccrualEnrollment[]
}

model LeaveAccrualEnrollment {
  id             String    @id @default(cuid())
  planId         String
  employeeId     String
  startDate      DateTime
  currentBalance Float     @default(0)
  totalAccrued   Float     @default(0)
  totalUsed      Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  plan           LeaveAccrualPlan @relation(fields: [planId], references: [id])
  employee       Employee         @relation(fields: [employeeId], references: [id])
}

model Questionnaire {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String    @default("survey")
  status      String    @default("draft")
  anonymous   Boolean   @default(false)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  questions   QuestionnaireQuestion[]
  responses   QuestionnaireResponse[]
}

model QuestionnaireQuestion {
  id              String    @id @default(cuid())
  questionnaireId String
  sortOrder       Int
  questionText    String
  questionType    String    @default("text")
  required        Boolean   @default(true)
  optionsJson     String?
  createdAt       DateTime  @default(now())
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  answers         QuestionnaireAnswer[]
}

model QuestionnaireResponse {
  id              String    @id @default(cuid())
  questionnaireId String
  employeeId      String?
  submittedAt     DateTime  @default(now())
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id])
  employee        Employee?     @relation(fields: [employeeId], references: [id])
  answers         QuestionnaireAnswer[]
}

model QuestionnaireAnswer {
  id          String    @id @default(cuid())
  responseId  String
  questionId  String
  answerText  String?
  answerValue Float?
  createdAt   DateTime  @default(now())
  response    QuestionnaireResponse    @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question    QuestionnaireQuestion    @relation(fields: [questionId], references: [id])
}

model Shift {
  id         String   @id @default(cuid())
  employeeId String
  storeId    String
  startTime  DateTime
  endTime    DateTime
  status     String   @default("scheduled")
  notes      String?
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  store    Store    @relation(fields: [storeId], references: [id])
}

model ProductCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  color     String?
  icon      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  parent   ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id           String   @id @default(cuid())
  sku          String   @unique
  barcode      String?  @unique
  name         String
  description  String?
  categoryId   String?
  costPrice    Float    @default(0)
  salePrice    Float    @default(0)
  unit         String   @default("each")
  taxable      Boolean  @default(true)
  trackStock   Boolean  @default(true)
  isActive     Boolean  @default(true)
  imageUrl     String?
  supplierId   String?
  reorderPoint Int?
  reorderQty   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category           ProductCategory?    @relation(fields: [categoryId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  inventory          Inventory[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  wmsBinContents     WmsBinContent[]
  wmsEntries         WmsEntry[]
  attributes         ProductAttributeValue[]
  variantGroup       ProductVariantGroup?
  planningLines      ProjectPlanLine[]
  quoteLines         SalesQuoteLine[]
  serviceItems       ServiceItem[]       @relation("ProductServiceItems")
  // Manufacturing relations
  bomOutputs         ProductionBOM[]     @relation("BOMOutputProduct")
  bomComponents      ProductionBOMLine[] @relation("BOMComponent")
  productionOrders   ProductionOrder[]   @relation("ProductionOrderProduct")
  productionLines    ProductionOrderLine[] @relation("ProductionOrderLineProduct")
  subcontractingLines SubcontractingLine[] @relation("SubcontractingLineProduct")
  engineeringChanges EngineeringChangeLine[]
  whReceiptLines     WarehouseReceiptLine[]
  whShipmentLines    WarehouseShipmentLine[]
  whActivityLines    WarehouseActivityLine[]
  whPickLines        WarehousePickLine[]
  whPutAwayLines     WarehousePutAwayLine[]
  whMovementLines    WarehouseMovementLine[]
  whInternalPickLines WarehouseInternalPickLine[]
  whBinContents      WarehouseBinContent[]
}

model ProductAttribute {
  id         String   @id @default(cuid())
  name       String   @unique
  attrType   String   @default("text")
  isRequired Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  values     ProductAttributeValue[]
}

model ProductAttributeValue {
  id          String  @id @default(cuid())
  productId   String
  attributeId String
  value       String
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id])
  @@unique([productId, attributeId])
}

model ProductVariantGroup {
  id         String   @id @default(cuid())
  productId  String   @unique
  createdAt  DateTime @default(now())
  dimensions VariantDimension[]
  variants   ProductVariant[]
  product    Product  @relation(fields: [productId], references: [id])
}

model VariantDimension {
  id        String  @id @default(cuid())
  groupId   String
  name      String
  values    String
  sortOrder Int     @default(0)
  group     ProductVariantGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id         String   @id @default(cuid())
  groupId    String
  sku        String   @unique
  barcode    String?
  dimensions String
  costPrice  Float    @default(0)
  salePrice  Float    @default(0)
  stockQty   Float    @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  group      ProductVariantGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Assortment {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("draft")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lines       AssortmentLine[]
  channels    AssortmentChannel[]
}

model AssortmentLine {
  id           String  @id @default(cuid())
  assortmentId String
  productId    String?
  categoryId   String?
  lineType     String  @default("product")
  assortment   Assortment @relation(fields: [assortmentId], references: [id], onDelete: Cascade)
}

model AssortmentChannel {
  id           String  @id @default(cuid())
  assortmentId String
  channelId    String
  assortment   Assortment @relation(fields: [assortmentId], references: [id], onDelete: Cascade)
  @@unique([assortmentId, channelId])
}

model Customer {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String?  @unique
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  loyaltyPoints  Int      @default(0)
  totalSpent     Float    @default(0)
  visitCount     Int      @default(0)
  notes          String?
  tags           String?
  creditLimit    Float    @default(0)
  creditStatus   String   @default("good")  // good | warning | hold
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders             Order[]
  communications     Communication[]
  arInvoices         CustomerInvoice[]
  paymentSettlements CustomerPaymentSettlement[]
  campaignContacts   CampaignContact[]
  workOrders         WorkOrder[]
  loyaltyCard        LoyaltyCard?
  projects           Project[]
  contracts          Contract[]
  salesQuotes        SalesQuote[]
  salesOrders        SalesOrder[]      @relation("SalesOrderSellTo")
  salesInvoices      SalesInvoice[]    @relation("SalesInvoiceSellTo")
  salesCreditMemos   SalesCreditMemo[] @relation("SalesCreditMemoSellTo")
  salesReturnOrders  SalesReturnOrder[] @relation("SalesReturnOrderSellTo")
  serviceContracts   ServiceContract[] @relation("CustomerServiceContracts")
  serviceItems       ServiceItem[]     @relation("CustomerServiceItems")
  serviceOrders      ServiceOrder[]    @relation("CustomerServiceOrders")
  segmentMemberships ContactSegmentMember[]
  proformaInvoices   ProformaInvoice[]
  subscriptionOrders SubscriptionOrder[]
}

model Order {
  id             String   @id @default(cuid())
  orderNumber    String   @unique
  storeId        String
  customerId     String?
  status         String   @default("pending")
  subtotal       Float    @default(0)
  taxAmount      Float    @default(0)
  discountAmount Float    @default(0)
  totalAmount    Float    @default(0)
  paymentMethod  String?
  amountTendered Float?
  changeDue      Float?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  payments Payment[]

  posShiftId String?
  posShift   PosShift? @relation(fields: [posShiftId], references: [id])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  sku         String
  quantity    Float
  unitPrice   Float
  discount    Float   @default(0)
  taxAmount   Float   @default(0)
  lineTotal   Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        String   @id @default(cuid())
  orderId   String
  method    String
  amount    Float
  reference String?
  status    String   @default("completed")
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Inventory {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  quantity  Float    @default(0)
  reserved  Float    @default(0)
  location  String?
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])

  @@unique([productId, storeId])
}

model InventoryTransaction {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  type      String
  quantity  Float
  beforeQty Float
  afterQty  Float
  reference String?
  notes     String?
  createdBy String?
  createdAt DateTime @default(now())
}

model Supplier {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  zip          String?
  paymentTerms String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products       Product[]
  purchaseOrders PurchaseOrder[]
  contracts      Contract[]
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  poNumber     String    @unique
  supplierId   String
  storeId      String
  status       String    @default("draft")
  subtotal     Float     @default(0)
  taxAmount    Float     @default(0)
  shippingCost Float     @default(0)
  totalAmount  Float     @default(0)
  expectedDate DateTime?
  receivedDate DateTime?
  notes        String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  store     Store                @relation(fields: [storeId], references: [id])
  items     PurchaseOrderItem[]
  receipts  PurchaseReceipt[]
}

model PurchaseOrderItem {
  id          String  @id @default(cuid())
  poId        String
  productId   String
  productName String
  sku         String
  orderedQty  Float
  receivedQty Float   @default(0)
  unitCost    Float
  lineTotal   Float

  purchaseOrder PurchaseOrder        @relation(fields: [poId], references: [id], onDelete: Cascade)
  product       Product               @relation(fields: [productId], references: [id])
  receiptLines  PurchaseReceiptLine[]
}

model ServiceCase {
  id              String         @id @default(cuid())
  caseNumber      String         @unique
  customerId      String?
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  channel         String         @default("email")
  subject         String
  description     String?
  category        String         @default("general")
  priority        String         @default("normal")
  status          String         @default("open")
  assignedTo      String?
  resolvedAt      DateTime?
  firstResponseAt DateTime?
  slaDueAt        DateTime?
  slaBreached     Boolean        @default(false)
  resolutionNotes String?
  satisfaction    Int?
  orderId         String?
  activities      CaseActivity[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model CaseActivity {
  id           String      @id @default(cuid())
  caseId       String
  case         ServiceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  activityType String      @default("note")
  body         String
  authorName   String?
  isInternal   Boolean     @default(false)
  emailSubject String?
  duration     Int?
  createdAt    DateTime    @default(now())
}

model SlaPolicy {
  id                String   @id @default(cuid())
  name              String
  priority          String   @default("normal")
  firstResponseHrs  Int      @default(4)
  resolutionHrs     Int      @default(24)
  businessHoursOnly Boolean  @default(true)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model KnowledgeArticle {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  category     String    @default("general")
  body         String
  summary      String?
  tags         String?
  status       String    @default("draft")
  publishedAt  DateTime?
  viewCount    Int       @default(0)
  helpfulCount Int       @default(0)
  authorName   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ChatSession {
  id            String        @id @default(cuid())
  sessionNumber String        @unique
  customerId    String?
  customerName  String?
  customerEmail String?
  agentName     String?
  status        String        @default("waiting")
  queueId       String?
  waitTime      Int           @default(0)
  duration      Int?
  caseId        String?
  messages      ChatMessage[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderType  String      @default("customer")
  senderName  String?
  body        String
  createdAt   DateTime    @default(now())
}

model ServiceQueue {
  id          String   @id @default(cuid())
  name        String
  queueType   String   @default("cases")
  assignedTo  String   @default("[]")
  maxWaitTime Int      @default(300)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Communication {
  id         String   @id @default(cuid())
  customerId String
  channel    String
  direction  String
  subject    String?
  content    String?
  status     String   @default("sent")
  createdBy  String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  type        String
  status      String    @default("draft")
  subject     String?
  content     String?
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  targetCount Int       @default(0)
  sentCount   Int       @default(0)
  openCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contacts CampaignContact[]
}

model WorkOrder {
  id           String    @id @default(cuid())
  woNumber     String    @unique
  storeId      String
  customerId   String?
  title        String
  description  String?
  status       String    @default("new")
  priority     String    @default("medium")
  assignedTo   String?
  scheduledAt  DateTime?
  completedAt  DateTime?
  estimatedHrs Float?
  actualHrs    Float?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  store    Store           @relation(fields: [storeId], references: [id])
  customer Customer?       @relation(fields: [customerId], references: [id])
  lines    WorkOrderLine[]
}

// ─── General Ledger ───────────────────────────────────────────────────────────

model Account {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  type              String   // asset | liability | equity | revenue | expense
  subtype           String?
  mainAccountType   String?  // BC: balance_sheet | profit_loss (drives year-end behavior)
  openingAccountId  String?  // BC: where balance transfers to on year-end close
  balance           Float    @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  journalLines    JournalLine[]
  bankAccounts    BankAccount[]
  postingDebits   PostingRule[]  @relation("PostingRuleDebit")
  postingCredits  PostingRule[]  @relation("PostingRuleCredit")
  budgetEntries   BudgetEntry[]
  taxCodes        TaxCode[]
}

model JournalEntry {
  id          String   @id @default(cuid())
  reference   String
  description String?
  date        DateTime @default(now())
  status      String   @default("posted")  // posted | reversed
  createdBy   String?
  createdAt   DateTime @default(now())

  lines JournalLine[]
}

model JournalLine {
  id        String  @id @default(cuid())
  entryId   String
  accountId String
  debit     Float   @default(0)
  credit    Float   @default(0)
  memo      String?

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])
}

// ─── Business Central: G/L Entries (read-only ledger) ────────────────────────

model GlEntry {
  id            String   @id @default(cuid())
  entryNo       Int      @default(0)
  postingDate   DateTime @default(now())
  documentType  String?  // Invoice | Credit Memo | Payment | Refund | General
  documentNo    String?
  accountId     String?
  accountNo     String?
  accountName   String?
  description   String?
  debitAmount   Float    @default(0)
  creditAmount  Float    @default(0)
  amount        Float    @default(0)
  vatAmount     Float    @default(0)
  sourceCode    String?
  reasonCode    String?
  userId        String?
  journalId     String?
  fiscalYear    String?
  periodNo      Int?
  open          Boolean  @default(true)
  createdAt     DateTime @default(now())
}

// ─── Business Central: Accounting Periods ────────────────────────────────────

model AccountingPeriod {
  id               String   @id @default(cuid())
  startingDate     DateTime @unique
  name             String
  newFiscalYear    Boolean  @default(false)
  closed           Boolean  @default(false)
  dateLocked       Boolean  @default(false)
  inventoryClosed  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── Business Central: Cost Types (Cost Accounting) ──────────────────────────

model CostType {
  id              String   @id @default(cuid())
  no              String   @unique
  name            String
  type            String   @default("cost_type")  // cost_type | heading | total | begin_total | end_total
  glAccountRange  String?
  costCenterId    String?
  blocked         Boolean  @default(false)
  indentation     Int      @default(0)
  totalingRange   String?
  netChange       Float    @default(0)
  balance         Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Business Central: Vendor / AP ───────────────────────────────────────────

model VendorGroup {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  defaultPayTerms String?  // Net30 | Net60 | COD
  description     String?
  createdAt       DateTime @default(now())

  vendors Vendor[]
}

model Vendor {
  id             String   @id @default(cuid())
  vendorCode     String   @unique
  name           String
  vendorGroupId  String?
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  taxId          String?
  paymentTerms   String?  // Net30 | Net60 | Net15 | COD | Immediate
  paymentMethod  String?  // Check | ACH | Wire | Cash
  currency       String   @default("USD")
  creditLimit    Float?
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendorGroup          VendorGroup?          @relation(fields: [vendorGroupId], references: [id])
  invoices             VendorInvoice[]
  payments             VendorPayment[]
  purchaseOrders       VendorPO[]
  scorecards           VendorScorecard[]
  subcontractingOrders SubcontractingOrder[]
  incomingDocuments    IncomingDocument[]
  projectSubcontracts  ProjectSubcontract[]
}

model VendorInvoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  vendorId        String
  invoiceDate     DateTime
  dueDate         DateTime
  postingDate     DateTime @default(now())
  subtotal        Float
  taxAmount       Float    @default(0)
  totalAmount     Float
  paidAmount      Float    @default(0)
  status          String   @default("draft")   // draft | posted | matched | paid | partial | cancelled
  matchingStatus  String   @default("none")    // none | two_way | three_way
  poId            String?
  journalEntryId  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor      Vendor                    @relation(fields: [vendorId], references: [id])
  lines       VendorInvoiceLine[]
  settlements VendorPaymentSettlement[]
}

model VendorInvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  accountCode String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  lineAmount  Float
  taxAmount   Float   @default(0)

  invoice VendorInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model VendorPayment {
  id             String   @id @default(cuid())
  paymentNumber  String   @unique
  vendorId       String
  paymentDate    DateTime
  amount         Float
  paymentMethod  String   @default("Check")  // Check | ACH | Wire | Cash
  bankAccountId  String?
  checkNumber    String?
  status         String   @default("draft")  // draft | posted | cleared | voided
  journalEntryId String?
  notes          String?
  createdAt      DateTime @default(now())

  vendor      Vendor                    @relation(fields: [vendorId], references: [id])
  bankAccount BankAccount?              @relation(fields: [bankAccountId], references: [id])
  settlements VendorPaymentSettlement[]
}

model VendorPaymentSettlement {
  id            String   @id @default(cuid())
  paymentId     String
  invoiceId     String
  settledAmount Float
  discountTaken Float    @default(0)
  settledAt     DateTime @default(now())

  payment VendorPayment @relation(fields: [paymentId], references: [id])
  invoice VendorInvoice @relation(fields: [invoiceId], references: [id])
}

// ─── Business Central: Customer / AR ─────────────────────────────────────────

model CustomerInvoice {
  id             String   @id @default(cuid())
  invoiceNumber  String   @unique
  customerId     String
  orderId        String?
  invoiceDate    DateTime
  dueDate        DateTime
  postingDate    DateTime @default(now())
  subtotal       Float
  taxAmount      Float    @default(0)
  totalAmount    Float
  paidAmount     Float    @default(0)
  status         String   @default("draft")  // draft | posted | paid | partial | cancelled
  invoiceType    String   @default("sales")  // sales | free_text
  journalEntryId String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer    Customer                    @relation(fields: [customerId], references: [id])
  lines       CustomerInvoiceLine[]
  settlements CustomerPaymentSettlement[]
}

model CustomerInvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  accountCode String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  lineAmount  Float
  taxAmount   Float   @default(0)

  invoice CustomerInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model CustomerPaymentSettlement {
  id            String   @id @default(cuid())
  customerId    String
  invoiceId     String
  paymentRef    String?
  settledAmount Float
  discountTaken Float    @default(0)
  settledAt     DateTime @default(now())

  customer Customer        @relation(fields: [customerId], references: [id])
  invoice  CustomerInvoice @relation(fields: [invoiceId], references: [id])
}

// ─── Business Central: Bank & Cash Management ─────────────────────────────────

model BankAccount {
  id              String   @id @default(cuid())
  accountCode     String   @unique
  name            String?
  bankName        String
  accountNumber   String
  routingNumber   String?
  accountType     String   @default("checking")  // checking | savings | credit_line
  currency        String   @default("USD")
  currentBalance  Float    @default(0)
  glAccountId     String?
  isActive        Boolean  @default(true)
  isPrimary       Boolean  @default(false)
  // Communication
  contactName     String?
  phone           String?
  email           String?
  address         String?
  city            String?
  state           String?
  zip             String?
  country         String?
  // Transfer / SWIFT
  swiftCode       String?
  ibanNumber      String?
  // Posting
  lastStatementNo String?
  lastStatementDate DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  glAccount        Account?             @relation(fields: [glAccountId], references: [id])
  statements       BankStatement[]
  vendorPayments   VendorPayment[]
  reconciliations  BankReconciliation[]
  transactions     BankTransaction[]
}

model BankStatement {
  id             String   @id @default(cuid())
  bankAccountId  String
  statementDate  DateTime
  openingBalance Float
  closingBalance Float
  status         String   @default("pending")  // pending | in_progress | reconciled
  importedAt     DateTime @default(now())
  reconciledAt   DateTime?

  bankAccount BankAccount         @relation(fields: [bankAccountId], references: [id])
  lines       BankStatementLine[]
}

model BankStatementLine {
  id              String   @id @default(cuid())
  statementId     String
  transactionDate DateTime
  description     String
  amount          Float
  transactionType String   @default("deposit")  // deposit | withdrawal | fee | interest
  reference       String?
  matchingStatus  String   @default("unmatched")  // unmatched | matched | manual
  matchedToId     String?
  createdAt       DateTime @default(now())

  statement BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
}

// ─── Business Central: Fiscal Calendar & Year-End Close ──────────────────────

model FiscalYear {
  id         String   @id @default(cuid())
  name       String   @unique  // e.g., FY2026
  startDate  DateTime
  endDate    DateTime
  status     String   @default("open")  // open | closing | closed | archived
  closedAt   DateTime?
  closedBy   String?
  createdAt  DateTime @default(now())

  periods      FiscalPeriod[]
  yearEndClose YearEndClose?
}

model FiscalPeriod {
  id           String   @id @default(cuid())
  fiscalYearId String
  periodNumber Int
  name         String
  startDate    DateTime
  endDate      DateTime
  status       String   @default("open")  // open | closed | on_hold
  closedAt     DateTime?

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id])

  @@unique([fiscalYearId, periodNumber])
}

model YearEndClose {
  id                        String   @id @default(cuid())
  fiscalYearId              String   @unique
  closingDate               DateTime
  status                    String   @default("pending")  // pending | in_progress | completed | reversed
  retainedEarningsAccountId String?
  openingVoucherId          String?
  closingVoucherId          String?
  totalRevenue              Float    @default(0)
  totalExpenses             Float    @default(0)
  netIncome                 Float    @default(0)
  completedAt               DateTime?
  completedBy               String?
  notes                     String?
  createdAt                 DateTime @default(now())

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id])
}

// ─── Business Central: Posting Profiles ──────────────────────────────────────

model PostingProfile {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  module      String   // AP | AR | INVENTORY | BANK | PAYROLL
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  rules PostingRule[]
}

model PostingRule {
  id              String  @id @default(cuid())
  profileId       String
  transactionType String  // VendorInvoice | CustomerInvoice | VendorPayment | CustomerPayment | Inventory | etc.
  debitAccountId  String?
  creditAccountId String?
  applicableTo    String? // ALL | group code

  profile       PostingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  debitAccount  Account?       @relation("PostingRuleDebit", fields: [debitAccountId], references: [id])
  creditAccount Account?       @relation("PostingRuleCredit", fields: [creditAccountId], references: [id])
}

// ─── Warehouse Management System ─────────────────────────────────────────────

model WmsLocation {
  id              String   @id @default(cuid())
  locationCode    String   @unique
  name            String
  address         String?
  city            String?
  state           String?
  requireReceive  Boolean  @default(false)
  requireShipment Boolean  @default(false)
  requirePick     Boolean  @default(false)
  requirePutaway  Boolean  @default(false)
  binMandatory    Boolean  @default(true)
  isCrossDock     Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  zones            WmsZone[]
  warehouseEntries WmsEntry[]
}

model WmsZone {
  id           String   @id @default(cuid())
  locationCode String
  zoneCode     String
  name         String
  zoneType     String   @default("STORAGE")
  layoutLeft   Float?
  layoutTop    Float?
  layoutWidth  Float?
  layoutHeight Float?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  location WmsLocation @relation(fields: [locationCode], references: [locationCode])
  racks    WmsRack[]

  @@unique([locationCode, zoneCode])
}

model WmsRack {
  id           String   @id @default(cuid())
  locationCode String
  zoneCode     String
  rackCode     String
  name         String?
  sections     Int      @default(1)
  levels       Int      @default(1)
  depth        Int      @default(1)
  binPrefix    String?
  binSeparator String   @default("-")
  reverseDir   Boolean  @default(false)
  digitCount   Int      @default(2)
  createdAt    DateTime @default(now())

  zone WmsZone @relation(fields: [locationCode, zoneCode], references: [locationCode, zoneCode])
  bins WmsBin[]

  @@unique([locationCode, zoneCode, rackCode])
}

model WmsBin {
  id           String   @id @default(cuid())
  locationCode String
  zoneCode     String
  rackCode     String?
  binCode      String
  description  String?
  binType      String   @default("STORAGE")
  maxVolume    Float?
  maxWeight    Float?
  isEmpty      Boolean  @default(true)
  isBlocked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rack     WmsRack?        @relation(fields: [locationCode, zoneCode, rackCode], references: [locationCode, zoneCode, rackCode])
  contents WmsBinContent[]

  @@unique([locationCode, zoneCode, binCode])
}

model WmsBinContent {
  id            String   @id @default(cuid())
  locationCode  String
  zoneCode      String
  binCode       String
  productId     String
  lotNumber     String?
  serialNumber  String?
  quantity      Float    @default(0)
  pickQty       Float    @default(0)
  putawayQty    Float    @default(0)
  posAdjmtQty   Float    @default(0)
  negAdjmtQty   Float    @default(0)
  state         String   @default("AVAILABLE")
  unitOfMeasure String   @default("each")
  updatedAt     DateTime @updatedAt

  bin     WmsBin  @relation(fields: [locationCode, zoneCode, binCode], references: [locationCode, zoneCode, binCode])
  product Product @relation(fields: [productId], references: [id])

  @@unique([locationCode, zoneCode, binCode, productId, lotNumber, serialNumber])
}

model WmsEntry {
  id             String   @id @default(cuid())
  entryNumber    String   @unique
  locationCode   String
  productId      String
  entryType      String
  fromBinCode    String?
  toBinCode      String?
  fromZoneCode   String?
  toZoneCode     String?
  quantity       Float
  lotNumber      String?
  serialNumber   String?
  referenceType  String?
  referenceId    String?
  truckNumber    String?
  shipmentNumber String?
  notes          String?
  postedBy       String?
  postedAt       DateTime @default(now())

  location WmsLocation @relation(fields: [locationCode], references: [locationCode])
  product  Product     @relation(fields: [productId], references: [id])
}

model FamilyCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  parentCode  String?
  createdAt   DateTime @default(now())

  parent   FamilyCategory?  @relation("FamilyCategoryTree", fields: [parentCode], references: [code])
  children FamilyCategory[] @relation("FamilyCategoryTree")
}

// ─── Fixed Assets ─────────────────────────────────────────────────────────────

model FixedAssetGroup {
  id                 String   @id @default(cuid())
  code               String   @unique
  name               String
  depreciationMethod String   @default("straight_line") // straight_line | declining_balance | sum_of_years
  usefulLifeYears    Int      @default(5)
  salvageValuePct    Float    @default(0.1)
  glAssetAccountId   String?
  glDeprecAccountId  String?
  glAccumAccountId   String?
  createdAt          DateTime @default(now())

  assets FixedAsset[]
}

model FixedAsset {
  id                 String   @id @default(cuid())
  assetNumber        String   @unique
  name               String
  description        String?
  groupId            String
  acquisitionDate    DateTime
  acquisitionCost    Float
  salvageValue       Float    @default(0)
  usefulLifeYears    Int
  depreciationMethod String   @default("straight_line")
  currentBookValue   Float
  accumulatedDeprec  Float    @default(0)
  status             String   @default("active") // active | disposed | fully_depreciated
  location           String?
  serialNumber       String?
  notes              String?
  disposedAt         DateTime?
  disposalAmount     Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  group              FixedAssetGroup       @relation(fields: [groupId], references: [id])
  depreciationLines  AssetDepreciation[]
}

model AssetDepreciation {
  id                     String   @id @default(cuid())
  assetId                String
  fiscalYear             String
  periodNumber           Int
  depreciationAmount     Float
  accumulatedDepreciation Float
  bookValueAfter         Float
  journalEntryId         String?
  postedAt               DateTime @default(now())

  asset FixedAsset @relation(fields: [assetId], references: [id])

  @@unique([assetId, fiscalYear, periodNumber])
}

// ─── Budget ───────────────────────────────────────────────────────────────────

model BudgetPlan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  fiscalYear   String   // e.g., FY2026
  status       String   @default("draft") // draft | active | closed
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entries BudgetEntry[]
}

model BudgetEntry {
  id           String   @id @default(cuid())
  budgetPlanId String
  accountId    String
  periodNumber Int?     // null = annual budget
  budgetAmount Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())

  budgetPlan BudgetPlan @relation(fields: [budgetPlanId], references: [id], onDelete: Cascade)
  account    Account    @relation(fields: [accountId], references: [id])

  @@unique([budgetPlanId, accountId, periodNumber])
}

// ─── Tax Management ───────────────────────────────────────────────────────────

model TaxCode {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  rate          Float    // percentage e.g. 8.25
  taxType       String   @default("sales") // sales | use | vat | exempt | withholding
  glAccountId   String?
  isActive      Boolean  @default(true)
  description   String?
  createdAt     DateTime @default(now())

  glAccount    Account?         @relation(fields: [glAccountId], references: [id])
  transactions TaxTransaction[]
}

model TaxTransaction {
  id             String   @id @default(cuid())
  taxCodeId      String
  sourceType     String   // order | vendor_invoice | customer_invoice | manual
  sourceId       String
  taxableAmount  Float
  taxAmount      Float
  taxDate        DateTime @default(now())
  fiscalYear     String?
  periodNumber   Int?

  taxCode TaxCode @relation(fields: [taxCodeId], references: [id])
}

// ─── Payroll ──────────────────────────────────────────────────────────────────

model PayrollPeriod {
  id          String   @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  payDate     DateTime
  status      String   @default("open") // open | processing | posted | closed
  fiscalYear  String?
  createdAt   DateTime @default(now())

  entries PayrollEntry[]
}

model PayrollEntry {
  id              String   @id @default(cuid())
  periodId        String
  employeeId      String
  regularHours    Float    @default(0)
  overtimeHours   Float    @default(0)
  hourlyRate      Float
  grossPay        Float
  federalTax      Float    @default(0)
  stateTax        Float    @default(0)
  socialSecurity  Float    @default(0)
  medicare        Float    @default(0)
  otherDeductions Float    @default(0)
  netPay          Float
  status          String   @default("draft") // draft | approved | paid
  journalEntryId  String?
  createdAt       DateTime @default(now())

  period   PayrollPeriod @relation(fields: [periodId], references: [id])
  employee Employee      @relation(fields: [employeeId], references: [id])
}

// ─── Cost Accounting ──────────────────────────────────────────────────────────

model CostCenter {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  type        String   @default("department") // department | project | region | product_line
  managerId   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  allocations CostAllocation[]
  entries     CostLedgerEntry[]
  budgets     CostBudget[]
}

model CostCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  type        String   @default("overhead") // personnel | overhead | materials | services | capex
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  entries     CostLedgerEntry[]
  budgets     CostBudget[]
}

model CostAllocation {
  id           String  @id @default(cuid())
  costCenterId String
  accountId    String?
  percentage   Float
  description  String?
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())

  costCenter CostCenter @relation(fields: [costCenterId], references: [id])
}

model CostLedgerEntry {
  id             String   @id @default(cuid())
  costCenterId   String
  costCategoryId String
  amount         Float
  description    String?
  sourceType     String   @default("manual") // manual | journal | payroll | fixed_asset | allocation
  sourceId       String?
  fiscalYear     String?
  periodNumber   Int?
  entryDate      DateTime @default(now())
  createdAt      DateTime @default(now())

  costCenter   CostCenter   @relation(fields: [costCenterId], references: [id])
  costCategory CostCategory @relation(fields: [costCategoryId], references: [id])
}

model CostBudget {
  id             String  @id @default(cuid())
  costCenterId   String
  costCategoryId String
  fiscalYear     String
  periodNumber   Int?
  budgetAmount   Float

  costCenter   CostCenter   @relation(fields: [costCenterId], references: [id])
  costCategory CostCategory @relation(fields: [costCategoryId], references: [id])

  @@unique([costCenterId, costCategoryId, fiscalYear, periodNumber])
}

// ─── Field Service Extensions ─────────────────────────────────────────────────

model WorkOrderLine {
  id          String  @id @default(cuid())
  workOrderId String
  lineType    String  @default("labor") // labor | part | expense
  description String
  quantity    Float   @default(1)
  unitCost    Float   @default(0)
  totalCost   Float   @default(0)
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

// ─── Purchasing Extensions ────────────────────────────────────────────────────

model PurchaseReceipt {
  id              String   @id @default(cuid())
  receiptNumber   String   @unique
  purchaseOrderId String
  receivedBy      String?
  receivedAt      DateTime @default(now())
  notes           String?

  purchaseOrder PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id])
  lines         PurchaseReceiptLine[]
}

model PurchaseReceiptLine {
  id              String @id @default(cuid())
  receiptId       String
  poItemId        String
  quantityReceived Float

  receipt PurchaseReceipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  poItem  PurchaseOrderItem @relation(fields: [poItemId], references: [id])
}

// ─── Price & Discount Management ─────────────────────────────────────────────

model PriceGroup {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  discounts   Discount[]
}

model Discount {
  id              String   @id @default(cuid())
  name            String
  discountCode    String   @unique
  discountType    String   // simple | quantity | mix_match | threshold
  status          String   @default("active") // active | inactive | expired
  priceGroupId    String?
  couponRequired  Boolean  @default(false)
  couponCode      String?
  discountMethod  String   @default("percent") // percent | amount
  discountValue   Float    @default(0)
  startDate       DateTime?
  endDate         DateTime?
  maxUsageCount   Int?
  usageCount      Int      @default(0)
  minPurchaseAmt  Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  priceGroup  PriceGroup?      @relation(fields: [priceGroupId], references: [id])
  lines       DiscountLine[]
  usages      DiscountUsage[]
}

model DiscountLine {
  id           String  @id @default(cuid())
  discountId   String
  lineType     String  // product | category | all
  productId    String?
  categoryId   String?
  minQty       Float?
  maxQty       Float?
  discountPct  Float?
  discountAmt  Float?

  discount  Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
}

model DiscountUsage {
  id          String   @id @default(cuid())
  discountId  String
  orderId     String
  discountAmt Float
  usedAt      DateTime @default(now())

  discount Discount @relation(fields: [discountId], references: [id])
}

model PriceAdjustment {
  id           String   @id @default(cuid())
  name         String
  productId    String?
  categoryId   String?
  priceGroupId String?
  adjustType   String   @default("percent") // percent | fixed | new_price
  adjustValue  Float
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ─── Loyalty Program ──────────────────────────────────────────────────────────

model LoyaltyProgram {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("active") // active | inactive
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tiers  LoyaltyTierLegacy[]
  cards  LoyaltyCard[]
}

model LoyaltyTierLegacy {
  id            String  @id @default(cuid())
  programId     String
  name          String
  minimumPoints Int     @default(0)
  earningRate   Float   @default(1.0)
  rewardRate    Float   @default(0.01)
  description   String?
  color         String?
  sortOrder     Int     @default(0)

  program LoyaltyProgram @relation(fields: [programId], references: [id])
  cards   LoyaltyCard[]
}

model LoyaltyCard {
  id              String    @id @default(cuid())
  cardNumber      String    @unique
  programId       String
  tierId          String?
  customerId      String    @unique
  totalPoints     Int       @default(0)
  availablePoints Int       @default(0)
  lifetimePoints  Int       @default(0)
  status          String    @default("active") // active | blocked | expired
  enrolledAt      DateTime  @default(now())
  lastActivity    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  program      LoyaltyProgram        @relation(fields: [programId], references: [id])
  tier         LoyaltyTierLegacy?    @relation(fields: [tierId], references: [id])
  customer     Customer              @relation(fields: [customerId], references: [id])
  transactions LoyaltyTransaction[]
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  cardId      String
  type        String   // earn | redeem | adjust | expire | enroll
  points      Int
  description String?
  orderId     String?
  createdAt   DateTime @default(now())

  card LoyaltyCard @relation(fields: [cardId], references: [id])
}

// ─── Marketing Extensions ─────────────────────────────────────────────────────

model CampaignContact {
  id           String    @id @default(cuid())
  campaignId   String
  customerId   String
  status       String    @default("pending") // pending | sent | opened | clicked | unsubscribed
  sentAt       DateTime?
  openedAt     DateTime?
  createdAt    DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([campaignId, customerId])
}

// ─── Gift Cards (Legacy) ──────────────────────────────────────────────────────

model GiftCardLegacy {
  id             String   @id @default(cuid())
  cardNumber     String   @unique
  initialBalance Float
  currentBalance Float
  currency       String   @default("USD")
  status         String   @default("active")
  issuedAt       DateTime @default(now())
  expiresAt      DateTime?
  issuedBy       String?
  customerId     String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions GiftCardTransaction[]
}

model GiftCardTransaction {
  id            String          @id @default(cuid())
  giftCardId    String
  type          String
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  orderId       String?
  reference     String?
  notes         String?
  createdBy     String?
  createdAt     DateTime        @default(now())

  giftCard GiftCardLegacy @relation(fields: [giftCardId], references: [id])
}

// ─── Commerce HQ / Channel Management ────────────────────────────────────────

model Channel {
  id               String   @id @default(cuid())
  channelCode      String   @unique
  name             String
  channelType      String   // retail | online | call_center
  storeId          String?
  defaultWarehouse String?
  currency         String   @default("USD")
  timeZone         String   @default("America/New_York")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  registers Register[]
}

model Register {
  id                String   @id @default(cuid())
  registerId        String   @unique
  name              String
  channelId         String
  hardwareProfileId String?
  screenLayoutId    String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  channel Channel   @relation(fields: [channelId], references: [id])
  shifts  CashShift[]
}

model HardwareProfile {
  id                         String        @id @default(cuid())
  profileNumber              String        @unique
  profileName                String
  hardwareStationType        String        @default("dedicated")
  cashDrawerDevice           String?
  cashDrawerOpenBeforeTender Boolean       @default(true)
  cashDrawerOpenBlindClose   Boolean       @default(false)
  barcodeDevice              String?
  barcodeKeyboardWedge       Boolean       @default(true)
  printerDevice              String?
  printerDriver              String?
  printerReceiptProfileId    String?
  printerLogoUrl             String?
  msrDevice                  String?
  customerDisplayActive      Boolean       @default(false)
  customerDisplayLines       Int           @default(2)
  scaleDevice                String?
  scaleUOM                   String?
  isActive                   Boolean       @default(true)
  registers                  POSRegister[]
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
}

model POSRegister {
  id                String           @id @default(cuid())
  registerNumber    String           @unique
  registerId        String?
  storeId           String?
  storeName         String?
  hardwareProfileId String?
  hardwareProfile   HardwareProfile? @relation(fields: [hardwareProfileId], references: [id])
  receiptProfileId  String?
  terminalType      String           @default("POS")
  status            String           @default("offline")
  lastActivityAt    DateTime?
  drawerLimit       Float            @default(500)
  isActive          Boolean          @default(true)
  shifts            RegisterShift[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model RegisterShift {
  id           String      @id @default(cuid())
  registerId   String
  register     POSRegister @relation(fields: [registerId], references: [id])
  shiftNumber  String      @unique @default(cuid())
  cashierId    String?
  cashierName  String?
  openedAt     DateTime    @default(now())
  closedAt     DateTime?
  openingFloat Float       @default(0)
  closingFloat Float?
  netSales     Float       @default(0)
  transactions Int         @default(0)
  status       String      @default("open")
  createdAt    DateTime    @default(now())
}

model ReceiptProfile {
  id           String   @id @default(cuid())
  profileId    String   @unique
  profileName  String
  receiptTypes String?
  headerLines  String?
  footerLines  String?
  showBarcode  Boolean  @default(true)
  barcodeType  String   @default("Code128")
  logoUrl      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PaymentConnector {
  id               String   @id @default(cuid())
  connectorName    String   @unique
  connectorType    String
  merchantId       String?
  apiEndpoint      String?
  supportedMethods String?
  isActive         Boolean  @default(true)
  isSandbox        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CashShift {
  id           String    @id @default(cuid())
  shiftNumber  String    @unique
  registerId   String
  employeeId   String?
  status       String    @default("open") // open | suspended | closed | blind_closed
  openingFloat Float     @default(0)
  cashSales    Float     @default(0)
  cardSales    Float     @default(0)
  giftCardSales Float    @default(0)
  returns      Float     @default(0)
  safeDrops    Float     @default(0)
  bankDrops    Float     @default(0)
  expectedCash Float     @default(0)
  countedCash  Float?
  variance     Float?
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  register        Register      @relation(fields: [registerId], references: [id])
  tenders         ShiftTender[]
  safeDropEntries SafeDrop[]
}

model ShiftTender {
  id      String    @id @default(cuid())
  shiftId String
  method  String
  amount  Float
  count   Int       @default(0)

  shift CashShift @relation(fields: [shiftId], references: [id])
}

model SafeDrop {
  id        String   @id @default(cuid())
  shiftId   String
  type      String   // safe_drop | bank_drop | float_entry
  amount    Float
  notes     String?
  createdAt DateTime @default(now())

  shift CashShift @relation(fields: [shiftId], references: [id])
}

// ─── Task Management ──────────────────────────────────────────────────────────

model TaskList {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("active")  // active | completed | archived
  dueDate     DateTime?
  storeId     String?
  assignedTo  String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
}

model Task {
  id          String   @id @default(cuid())
  taskListId  String
  title       String
  description String?
  status      String   @default("not_started")  // not_started | in_progress | completed | skipped
  priority    String   @default("normal")  // low | normal | high | critical
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  completedBy String?
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  taskList    TaskList @relation(fields: [taskListId], references: [id], onDelete: Cascade)
}

// ─── Commerce Statements ──────────────────────────────────────────────────────

model CommerceStatement {
  id              String   @id @default(cuid())
  statementNumber String   @unique
  storeId         String?
  channelId       String?
  fiscalPeriod    String?
  startDate       DateTime
  endDate         DateTime
  status          String   @default("open")  // open | calculated | posted | voided
  totalSales      Float    @default(0)
  totalReturns    Float    @default(0)
  totalDiscounts  Float    @default(0)
  totalTax        Float    @default(0)
  totalCash       Float    @default(0)
  totalCard       Float    @default(0)
  totalGiftCard   Float    @default(0)
  transactionCount Int     @default(0)
  variance        Float    @default(0)
  calculatedAt    DateTime?
  postedAt        DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Customer Orders / Fulfillment / Returns ──────────────────────────────────

model CustomerOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  customerId      String
  status          String   @default("created")  // created | confirmed | picking | packed | shipped | delivered | cancelled | return_in_progress
  orderType       String   @default("pickup")   // pickup | ship | carry_out
  channelId       String?
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  deliveryMode    String?
  requestedDate   DateTime?
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  shippingCost    Float    @default(0)
  totalAmount     Float    @default(0)
  depositPaid     Float    @default(0)
  balanceDue      Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lines           CustomerOrderLine[]
  fulfillments    OrderFulfillment[]
}

model CustomerOrderLine {
  id            String  @id @default(cuid())
  orderId       String
  productId     String
  productName   String
  sku           String
  quantity      Float
  unitPrice     Float
  discount      Float   @default(0)
  taxAmount     Float   @default(0)
  lineTotal     Float
  qtyFulfilled  Float   @default(0)
  status        String  @default("open")  // open | picking | packed | fulfilled | cancelled
  order         CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderFulfillment {
  id            String   @id @default(cuid())
  orderId       String
  fulfillmentNo String   @unique
  status        String   @default("pending")  // pending | picking | packing | packed | shipped | delivered
  storeId       String?
  assignedTo    String?
  trackingNo    String?
  carrier       String?
  packedAt      DateTime?
  shippedAt     DateTime?
  deliveredAt   DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  order         CustomerOrder @relation(fields: [orderId], references: [id])
  lines         FulfillmentLine[]
}

model FulfillmentLine {
  id              String  @id @default(cuid())
  fulfillmentId   String
  orderLineId     String
  quantity        Float
  fulfillment     OrderFulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
}

model ReturnOrder {
  id              String   @id @default(cuid())
  returnNumber    String   @unique
  originalOrderId String?
  customerId      String?
  status          String   @default("open")
  returnReason    String?
  refundMethod    String   @default("original")
  totalRefund     Float    @default(0)
  restockFee      Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Commerce Site Builder ─────────────────────────────────────────────────────

model SitePage {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  title         String
  description   String?
  status        String    @default("draft")    // draft, checked-out, checked-in, published
  checkedOutBy  String?
  checkedOutAt  DateTime?
  publishedAt   DateTime?
  pageType      String    @default("content")  // content, category, product, home, search, cart, checkout
  template      String    @default("default")
  metaTitle     String?
  metaDesc      String?
  robotsIndex   Boolean   @default(true)
  modules       SitePageModule[]
  fragments     SiteFragment[]
  versions      SitePageVersion[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SitePageModule {
  id         String   @id @default(cuid())
  pageId     String
  page       SitePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  moduleType String   // hero, text-block, product-grid, image-gallery, call-to-action, video, carousel, promo-banner, nav-menu, footer, breadcrumb, buy-box, ratings-reviews, related-products, recommended, search-result, cart-icon, sign-in, iframe, form, spacer
  name       String
  position   Int
  parentId   String?
  config     String   @default("{}")  // JSON config for module props
  hidden     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SiteFragment {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  moduleType  String
  config      String   @default("{}")
  usageCount  Int      @default(0)
  pages       SitePage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SitePageVersion {
  id          String   @id @default(cuid())
  pageId      String
  page        SitePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  version     Int
  snapshot    String   // JSON snapshot of page + modules
  publishedBy String?
  publishedAt DateTime @default(now())
}

model SiteTheme {
  id           String   @id @default(cuid())
  name         String
  isActive     Boolean  @default(false)
  primaryColor String   @default("#0078d4")
  fontFamily   String   @default("Segoe UI")
  logoUrl      String?
  faviconUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteNavMenu {
  id        String        @id @default(cuid())
  name      String
  location  String        // header, footer, sidebar
  isActive  Boolean       @default(true)
  items     SiteNavItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SiteNavItem {
  id       String      @id @default(cuid())
  menuId   String
  menu     SiteNavMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label    String
  url      String
  position Int
  parentId String?
  openNew  Boolean     @default(false)
}

// ─── Call Center ──────────────────────────────────────────────────────────────

model CallCenterOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique @default(cuid())
  customerId      String?
  agentId         String?
  agentName       String?
  channel         String   @default("phone")
  status          String   @default("draft")
  holdReason      String?
  fraudScore      Int      @default(0)
  fraudFlags      String?
  subtotal        Float    @default(0)
  tax             Float    @default(0)
  shipping        Float    @default(0)
  total           Float    @default(0)
  paymentMethod   String?
  paymentRef      String?
  notes           String?
  lines           CallCenterOrderLine[]
  holds           CallCenterHold[]
  rmas            CallCenterRMA[]
  continuityEnrollments CallCenterContinuity[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CallCenterOrderLine {
  id             String          @id @default(cuid())
  orderId        String
  order          CallCenterOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String?
  productName    String
  sku            String?
  qty            Int             @default(1)
  unitPrice      Float
  discount       Float           @default(0)
  lineTotal      Float
  overrideBy     String?
  overrideReason String?
  createdAt      DateTime        @default(now())
}

model CallCenterHold {
  id         String          @id @default(cuid())
  orderId    String
  order      CallCenterOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  holdType   String
  reason     String
  placedBy   String?
  releasedBy String?
  releasedAt DateTime?
  status     String          @default("active")
  notes      String?
  createdAt  DateTime        @default(now())
}

model CallCenterRMA {
  id           String          @id @default(cuid())
  orderId      String
  order        CallCenterOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rmaNumber    String          @unique
  reason       String
  disposition  String          @default("refund")
  status       String          @default("pending")
  refundAmount Float           @default(0)
  items        String          @default("[]")
  approvedBy   String?
  processedAt  DateTime?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model CallCenterContinuity {
  id           String           @id @default(cuid())
  orderId      String?
  order        CallCenterOrder? @relation(fields: [orderId], references: [id])
  customerId   String?
  programName  String
  productName  String
  frequency    String           @default("monthly")
  price        Float
  nextShipDate DateTime?
  status       String           @default("active")
  shipCount    Int              @default(0)
  maxShips     Int?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model CallCenterScript {
  id        String   @id @default(cuid())
  name      String
  trigger   String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CallCenterFraudRule {
  id        String   @id @default(cuid())
  ruleName  String
  ruleType  String
  threshold Float?
  action    String   @default("flag")
  points    Int      @default(10)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Distributed Order Management (DOM) ──────────────────────────────────────

model DomProfile {
  id                String      @id @default(cuid())
  name              String
  isDefault         Boolean     @default(false)
  maxFulfillSplits  Int         @default(3)
  costWeight        Float       @default(0.4)
  distanceWeight    Float       @default(0.3)
  inventoryWeight   Float       @default(0.3)
  allowPartialFill  Boolean     @default(true)
  rules             DomRule[]
  fulfillmentGroups DomFulfillmentGroup[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model DomRule {
  id          String     @id @default(cuid())
  profileId   String
  profile     DomProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  ruleType    String
  name        String
  priority    Int        @default(0)
  parameters  String     @default("{}")
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
}

model DomFulfillmentGroup {
  id          String     @id @default(cuid())
  profileId   String
  profile     DomProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  groupType   String     @default("store")
  locationIds String     @default("[]")
  priority    Int        @default(0)
  maxOrders   Int?
  createdAt   DateTime   @default(now())
}

model DomOrderRun {
  id           String      @id @default(cuid())
  profileId    String?
  runAt        DateTime    @default(now())
  status       String      @default("running")
  ordersIn     Int         @default(0)
  ordersRouted Int         @default(0)
  ordersFailed Int         @default(0)
  duration     Int?
  results      DomResult[]
  createdAt    DateTime    @default(now())
}

model DomResult {
  id           String      @id @default(cuid())
  runId        String
  run          DomOrderRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  orderId      String?
  orderLine    String?
  productName  String?
  qty          Int         @default(1)
  assignedTo   String?
  assignedType String?
  routingScore Float       @default(0)
  splitNumber  Int         @default(1)
  reason       String?
  status       String      @default("routed")
  createdAt    DateTime    @default(now())
}

model DomExclusion {
  id           String    @id @default(cuid())
  locationId   String?
  locationName String?
  reason       String
  startDate    DateTime
  endDate      DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
}

// ─── Inventory Operations ─────────────────────────────────────────────────────

model InboundShipment {
