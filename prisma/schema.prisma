  modules       SitePageModule[]
  fragments     SiteFragment[]
  versions      SitePageVersion[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SitePageModule {
  id         String   @id @default(cuid())
  pageId     String
  page       SitePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  moduleType String   // hero, text-block, product-grid, image-gallery, call-to-action, video, carousel, promo-banner, nav-menu, footer, breadcrumb, buy-box, ratings-reviews, related-products, recommended, search-result, cart-icon, sign-in, iframe, form, spacer
  name       String
  position   Int
  parentId   String?
  config     String   @default("{}")  // JSON config for module props
  hidden     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SiteFragment {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  moduleType  String
  config      String   @default("{}")
  usageCount  Int      @default(0)
  pages       SitePage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SitePageVersion {
  id          String   @id @default(cuid())
  pageId      String
  page        SitePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  version     Int
  snapshot    String   // JSON snapshot of page + modules
  publishedBy String?
  publishedAt DateTime @default(now())
}

model SiteTheme {
  id           String   @id @default(cuid())
  name         String
  isActive     Boolean  @default(false)
  primaryColor String   @default("#0078d4")
  fontFamily   String   @default("Segoe UI")
  logoUrl      String?
  faviconUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteNavMenu {
  id        String        @id @default(cuid())
  name      String
  location  String        // header, footer, sidebar
  isActive  Boolean       @default(true)
  items     SiteNavItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SiteNavItem {
  id       String      @id @default(cuid())
  menuId   String
  menu     SiteNavMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label    String
  url      String
  position Int
  parentId String?
  openNew  Boolean     @default(false)
}
