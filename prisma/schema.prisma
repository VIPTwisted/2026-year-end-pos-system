generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  state     String?
  zip       String?
  phone     String?
  email     String?
  taxRate   Float    @default(0.0825)
  currency  String   @default("USD")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees      Employee[]
  orders         Order[]
  inventory      Inventory[]
  shifts         Shift[]
  purchaseOrders PurchaseOrder[]
  workOrders     WorkOrder[]
  storeTasks     StoreTask[]
  taskLists      TaskList[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   @default("cashier")
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee?
}

model Employee {
  id         String   @id @default(cuid())
  userId     String   @unique
  storeId    String
  firstName  String
  lastName   String
  position   String
  department String?
  hireDate   DateTime @default(now())
  hourlyRate Float?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user           User          @relation(fields: [userId], references: [id])
  store          Store         @relation(fields: [storeId], references: [id])
  shifts         Shift[]
  payrollEntries PayrollEntry[]
}

model Shift {
  id         String   @id @default(cuid())
  employeeId String
  storeId    String
  startTime  DateTime
  endTime    DateTime
  status     String   @default("scheduled")
  notes      String?
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  store    Store    @relation(fields: [storeId], references: [id])
}

model ProductCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  color     String?
  icon      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  parent   ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id           String   @id @default(cuid())
  sku          String   @unique
  barcode      String?  @unique
  name         String
  description  String?
  categoryId   String?
  costPrice    Float    @default(0)
  salePrice    Float    @default(0)
  unit         String   @default("each")
  taxable      Boolean  @default(true)
  trackStock   Boolean  @default(true)
  isActive     Boolean  @default(true)
  imageUrl     String?
  supplierId   String?
  reorderPoint Int?
  reorderQty   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category           ProductCategory?    @relation(fields: [categoryId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  inventory          Inventory[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  wmsBinContents     WmsBinContent[]
  wmsEntries         WmsEntry[]
}

model Customer {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String?  @unique
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  loyaltyPoints  Int      @default(0)
  totalSpent     Float    @default(0)
  visitCount     Int      @default(0)
  notes          String?
  tags           String?
  creditLimit    Float    @default(0)
  creditStatus   String   @default("good")  // good | warning | hold
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders             Order[]
  cases              ServiceCase[]
  communications     Communication[]
  arInvoices         CustomerInvoice[]
  paymentSettlements CustomerPaymentSettlement[]
  campaignContacts   CampaignContact[]
  workOrders         WorkOrder[]
  contacts           Contact[]
  opportunities      Opportunity[]
  giftCards          GiftCard[]
}

model Order {
  id             String   @id @default(cuid())
  orderNumber    String   @unique
  storeId        String
  customerId     String?
  status         String   @default("pending")
  subtotal       Float    @default(0)
  taxAmount      Float    @default(0)
  discountAmount Float    @default(0)
  totalAmount    Float    @default(0)
  paymentMethod  String?
  amountTendered Float?
  changeDue      Float?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  payments Payment[]
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  sku         String
  quantity    Float
  unitPrice   Float
  discount    Float   @default(0)
  taxAmount   Float   @default(0)
  lineTotal   Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        String   @id @default(cuid())
  orderId   String
  method    String
  amount    Float
  reference String?
  status    String   @default("completed")
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Inventory {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  quantity  Float    @default(0)
  reserved  Float    @default(0)
  location  String?
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])

  @@unique([productId, storeId])
}

model InventoryTransaction {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  type      String
  quantity  Float
  beforeQty Float
  afterQty  Float
  reference String?
  notes     String?
  createdBy String?
  createdAt DateTime @default(now())
}

model Supplier {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  zip          String?
  paymentTerms String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products       Product[]
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  poNumber     String    @unique
  supplierId   String
  storeId      String
  status       String    @default("draft")
  subtotal     Float     @default(0)
  taxAmount    Float     @default(0)
  shippingCost Float     @default(0)
  totalAmount  Float     @default(0)
  expectedDate DateTime?
  receivedDate DateTime?
  notes        String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  store     Store                @relation(fields: [storeId], references: [id])
  items     PurchaseOrderItem[]
  receipts  PurchaseReceipt[]
}

model PurchaseOrderItem {
  id          String  @id @default(cuid())
  poId        String
  productId   String
  productName String
  sku         String
  orderedQty  Float
  receivedQty Float   @default(0)
  unitCost    Float
  lineTotal   Float

  purchaseOrder PurchaseOrder        @relation(fields: [poId], references: [id], onDelete: Cascade)
  product       Product               @relation(fields: [productId], references: [id])
  receiptLines  PurchaseReceiptLine[]
}

model ServiceCase {
  id          String    @id @default(cuid())
  caseNumber  String    @unique
  customerId  String
  subject     String
  description String?
  status      String    @default("open")
  priority    String    @default("medium")
  category    String?
  assignedTo  String?
  resolvedAt  DateTime?
  slaBreached Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer Customer   @relation(fields: [customerId], references: [id])
  notes    CaseNote[]
}

model CaseNote {
  id        String   @id @default(cuid())
  caseId    String
  authorId  String?
  content   String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  case ServiceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model Communication {
  id         String   @id @default(cuid())
  customerId String
  channel    String
  direction  String
  subject    String?
  content    String?
  status     String   @default("sent")
  createdBy  String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  type        String
  status      String    @default("draft")
  subject     String?
  content     String?
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  targetCount Int       @default(0)
  sentCount   Int       @default(0)
  openCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contacts CampaignContact[]
}

model WorkOrder {
  id           String    @id @default(cuid())
  woNumber     String    @unique
  storeId      String
  customerId   String?
  title        String
  description  String?
  status       String    @default("new")
  priority     String    @default("medium")
  assignedTo   String?
  scheduledAt  DateTime?
  completedAt  DateTime?
  estimatedHrs Float?
  actualHrs    Float?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  store    Store           @relation(fields: [storeId], references: [id])
  customer Customer?       @relation(fields: [customerId], references: [id])
  lines    WorkOrderLine[]
}

// ─── General Ledger ───────────────────────────────────────────────────────────

model Account {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  type              String   // asset | liability | equity | revenue | expense
  subtype           String?
  mainAccountType   String?  // BC: balance_sheet | profit_loss (drives year-end behavior)
  openingAccountId  String?  // BC: where balance transfers to on year-end close
  balance           Float    @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  journalLines    JournalLine[]
  bankAccounts    BankAccount[]
  postingDebits   PostingRule[]  @relation("PostingRuleDebit")
  postingCredits  PostingRule[]  @relation("PostingRuleCredit")
  budgetEntries   BudgetEntry[]
  taxCodes        TaxCode[]
}

model JournalEntry {
  id          String   @id @default(cuid())
  reference   String
  description String?
  date        DateTime @default(now())
  status      String   @default("posted")  // posted | reversed
  createdBy   String?
  createdAt   DateTime @default(now())

  lines JournalLine[]
}

model JournalLine {
  id        String  @id @default(cuid())
  entryId   String
  accountId String
  debit     Float   @default(0)
  credit    Float   @default(0)
  memo      String?

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])
}

// ─── Business Central: Vendor / AP ───────────────────────────────────────────

model VendorGroup {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  defaultPayTerms String?  // Net30 | Net60 | COD
  description     String?
  createdAt       DateTime @default(now())

  vendors Vendor[]
}

model Vendor {
  id             String   @id @default(cuid())
  vendorCode     String   @unique
  name           String
  vendorGroupId  String?
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  taxId          String?
  paymentTerms   String?  // Net30 | Net60 | Net15 | COD | Immediate
  paymentMethod  String?  // Check | ACH | Wire | Cash
  currency       String   @default("USD")
  creditLimit    Float?
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendorGroup     VendorGroup?           @relation(fields: [vendorGroupId], references: [id])
  invoices        VendorInvoice[]
  payments        VendorPayment[]
}

model VendorInvoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  vendorId        String
  invoiceDate     DateTime
  dueDate         DateTime
  postingDate     DateTime @default(now())
  subtotal        Float
  taxAmount       Float    @default(0)
  totalAmount     Float
  paidAmount      Float    @default(0)
  status          String   @default("draft")   // draft | posted | matched | paid | partial | cancelled
  matchingStatus  String   @default("none")    // none | two_way | three_way
  poId            String?
  journalEntryId  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor      Vendor                    @relation(fields: [vendorId], references: [id])
  lines       VendorInvoiceLine[]
  settlements VendorPaymentSettlement[]
}

model VendorInvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  accountCode String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  lineAmount  Float
  taxAmount   Float   @default(0)

  invoice VendorInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model VendorPayment {
  id             String   @id @default(cuid())
  paymentNumber  String   @unique
  vendorId       String
  paymentDate    DateTime
  amount         Float
  paymentMethod  String   @default("Check")  // Check | ACH | Wire | Cash
  bankAccountId  String?
  checkNumber    String?
  status         String   @default("draft")  // draft | posted | cleared | voided
  journalEntryId String?
  notes          String?
  createdAt      DateTime @default(now())

  vendor      Vendor                    @relation(fields: [vendorId], references: [id])
  bankAccount BankAccount?              @relation(fields: [bankAccountId], references: [id])
  settlements VendorPaymentSettlement[]
}

model VendorPaymentSettlement {
  id            String   @id @default(cuid())
  paymentId     String
  invoiceId     String
  settledAmount Float
  discountTaken Float    @default(0)
  settledAt     DateTime @default(now())

  payment VendorPayment @relation(fields: [paymentId], references: [id])
  invoice VendorInvoice @relation(fields: [invoiceId], references: [id])
}

// ─── Business Central: Customer / AR ─────────────────────────────────────────

model CustomerInvoice {
  id             String   @id @default(cuid())
  invoiceNumber  String   @unique
  customerId     String
  orderId        String?
  invoiceDate    DateTime
  dueDate        DateTime
  postingDate    DateTime @default(now())
  subtotal       Float
  taxAmount      Float    @default(0)
  totalAmount    Float
  paidAmount     Float    @default(0)
  status         String   @default("draft")  // draft | posted | paid | partial | cancelled
  invoiceType    String   @default("sales")  // sales | free_text
  journalEntryId String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer    Customer                    @relation(fields: [customerId], references: [id])
  lines       CustomerInvoiceLine[]
  settlements CustomerPaymentSettlement[]
}

model CustomerInvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  accountCode String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  lineAmount  Float
  taxAmount   Float   @default(0)

  invoice CustomerInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model CustomerPaymentSettlement {
  id            String   @id @default(cuid())
  customerId    String
  invoiceId     String
  paymentRef    String?
  settledAmount Float
  discountTaken Float    @default(0)
  settledAt     DateTime @default(now())

  customer Customer        @relation(fields: [customerId], references: [id])
  invoice  CustomerInvoice @relation(fields: [invoiceId], references: [id])
}

// ─── Business Central: Bank & Cash Management ─────────────────────────────────

model BankAccount {
  id             String   @id @default(cuid())
  accountCode    String   @unique
  bankName       String
  accountNumber  String
  accountType    String   @default("checking")  // checking | savings
  currency       String   @default("USD")
  currentBalance Float    @default(0)
  glAccountId    String?
  isActive       Boolean  @default(true)
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  glAccount      Account?          @relation(fields: [glAccountId], references: [id])
  statements     BankStatement[]
  vendorPayments VendorPayment[]
}

model BankStatement {
  id             String   @id @default(cuid())
  bankAccountId  String
  statementDate  DateTime
  openingBalance Float
  closingBalance Float
  status         String   @default("pending")  // pending | in_progress | reconciled
  importedAt     DateTime @default(now())
  reconciledAt   DateTime?

  bankAccount BankAccount         @relation(fields: [bankAccountId], references: [id])
  lines       BankStatementLine[]
}

model BankStatementLine {
  id              String   @id @default(cuid())
  statementId     String
  transactionDate DateTime
  description     String
  amount          Float
  transactionType String   @default("deposit")  // deposit | withdrawal | fee | interest
  reference       String?
  matchingStatus  String   @default("unmatched")  // unmatched | matched | manual
  matchedToId     String?
  createdAt       DateTime @default(now())

  statement BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
}

// ─── Business Central: Fiscal Calendar & Year-End Close ──────────────────────

model FiscalYear {
  id         String   @id @default(cuid())
  name       String   @unique  // e.g., FY2026
  startDate  DateTime
  endDate    DateTime
  status     String   @default("open")  // open | closing | closed | archived
  closedAt   DateTime?
  closedBy   String?
  createdAt  DateTime @default(now())

  periods      FiscalPeriod[]
  yearEndClose YearEndClose?
}

model FiscalPeriod {
  id           String   @id @default(cuid())
  fiscalYearId String
  periodNumber Int
  name         String
  startDate    DateTime
  endDate      DateTime
  status       String   @default("open")  // open | closed | on_hold
  closedAt     DateTime?

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id])

  @@unique([fiscalYearId, periodNumber])
}

model YearEndClose {
  id                        String   @id @default(cuid())
  fiscalYearId              String   @unique
  closingDate               DateTime
  status                    String   @default("pending")  // pending | in_progress | completed | reversed
  retainedEarningsAccountId String?
  openingVoucherId          String?
  closingVoucherId          String?
  totalRevenue              Float    @default(0)
  totalExpenses             Float    @default(0)
  netIncome                 Float    @default(0)
  completedAt               DateTime?
  completedBy               String?
  notes                     String?
  createdAt                 DateTime @default(now())

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id])
}

// ─── Business Central: Posting Profiles ──────────────────────────────────────

model PostingProfile {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  module      String   // AP | AR | INVENTORY | BANK | PAYROLL
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  rules PostingRule[]
}

model PostingRule {
  id              String  @id @default(cuid())
  profileId       String
  transactionType String  // VendorInvoice | CustomerInvoice | VendorPayment | CustomerPayment | Inventory | etc.
  debitAccountId  String?
  creditAccountId String?
  applicableTo    String? // ALL | group code

  profile       PostingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  debitAccount  Account?       @relation("PostingRuleDebit", fields: [debitAccountId], references: [id])
  creditAccount Account?       @relation("PostingRuleCredit", fields: [creditAccountId], references: [id])
}

// ─── Warehouse Management System ─────────────────────────────────────────────

model WmsLocation {
  id              String   @id @default(cuid())
  locationCode    String   @unique
  name            String
  address         String?
  city            String?
  state           String?
  requireReceive  Boolean  @default(false)
  requireShipment Boolean  @default(false)
  requirePick     Boolean  @default(false)
  requirePutaway  Boolean  @default(false)
  binMandatory    Boolean  @default(true)
  isCrossDock     Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  zones            WmsZone[]
  warehouseEntries WmsEntry[]
}

model WmsZone {
  id           String   @id @default(cuid())
  locationCode String
  zoneCode     String
  name         String
  zoneType     String   @default("STORAGE")
  layoutLeft   Float?
  layoutTop    Float?
  layoutWidth  Float?
  layoutHeight Float?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  location WmsLocation @relation(fields: [locationCode], references: [locationCode])
  racks    WmsRack[]

  @@unique([locationCode, zoneCode])
}

model WmsRack {
  id           String   @id @default(cuid())
  locationCode String
  zoneCode     String
  rackCode     String
  name         String?
  sections     Int      @default(1)
  levels       Int      @default(1)
  depth        Int      @default(1)
  binPrefix    String?
  binSeparator String   @default("-")
  reverseDir   Boolean  @default(false)
  digitCount   Int      @default(2)
  createdAt    DateTime @default(now())

  zone WmsZone @relation(fields: [locationCode, zoneCode], references: [locationCode, zoneCode])
  bins WmsBin[]

  @@unique([locationCode, zoneCode, rackCode])
}

model WmsBin {
  id           String   @id @default(cuid())
  locationCode String
  zoneCode     String
  rackCode     String?
  binCode      String
  description  String?
  binType      String   @default("STORAGE")
  maxVolume    Float?
  maxWeight    Float?
  isEmpty      Boolean  @default(true)
  isBlocked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rack     WmsRack?        @relation(fields: [locationCode, zoneCode, rackCode], references: [locationCode, zoneCode, rackCode])
  contents WmsBinContent[]

  @@unique([locationCode, zoneCode, binCode])
}

model WmsBinContent {
  id            String   @id @default(cuid())
  locationCode  String
  zoneCode      String
  binCode       String
  productId     String
  lotNumber     String?
  serialNumber  String?
  quantity      Float    @default(0)
  pickQty       Float    @default(0)
  putawayQty    Float    @default(0)
  posAdjmtQty   Float    @default(0)
  negAdjmtQty   Float    @default(0)
  state         String   @default("AVAILABLE")
  unitOfMeasure String   @default("each")
  updatedAt     DateTime @updatedAt

  bin     WmsBin  @relation(fields: [locationCode, zoneCode, binCode], references: [locationCode, zoneCode, binCode])
  product Product @relation(fields: [productId], references: [id])

  @@unique([locationCode, zoneCode, binCode, productId, lotNumber, serialNumber])
}

model WmsEntry {
  id             String   @id @default(cuid())
  entryNumber    String   @unique
  locationCode   String
  productId      String
  entryType      String
  fromBinCode    String?
  toBinCode      String?
  fromZoneCode   String?
  toZoneCode     String?
  quantity       Float
  lotNumber      String?
  serialNumber   String?
  referenceType  String?
  referenceId    String?
  truckNumber    String?
  shipmentNumber String?
  notes          String?
  postedBy       String?
  postedAt       DateTime @default(now())

  location WmsLocation @relation(fields: [locationCode], references: [locationCode])
  product  Product     @relation(fields: [productId], references: [id])
}

model FamilyCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  parentCode  String?
  createdAt   DateTime @default(now())

  parent   FamilyCategory?  @relation("FamilyCategoryTree", fields: [parentCode], references: [code])
  children FamilyCategory[] @relation("FamilyCategoryTree")
}

// ─── Fixed Assets ─────────────────────────────────────────────────────────────

model FixedAssetGroup {
  id                 String   @id @default(cuid())
  code               String   @unique
  name               String
  depreciationMethod String   @default("straight_line") // straight_line | declining_balance | sum_of_years
  usefulLifeYears    Int      @default(5)
  salvageValuePct    Float    @default(0.1)
  glAssetAccountId   String?
  glDeprecAccountId  String?
  glAccumAccountId   String?
  createdAt          DateTime @default(now())

  assets FixedAsset[]
}

model FixedAsset {
  id                 String   @id @default(cuid())
  assetNumber        String   @unique
  name               String
  description        String?
  groupId            String
  acquisitionDate    DateTime
  acquisitionCost    Float
  salvageValue       Float    @default(0)
  usefulLifeYears    Int
  depreciationMethod String   @default("straight_line")
  currentBookValue   Float
  accumulatedDeprec  Float    @default(0)
  status             String   @default("active") // active | disposed | fully_depreciated
  location           String?
  serialNumber       String?
  notes              String?
  disposedAt         DateTime?
  disposalAmount     Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  group              FixedAssetGroup       @relation(fields: [groupId], references: [id])
  depreciationLines  AssetDepreciation[]
}

model AssetDepreciation {
  id                     String   @id @default(cuid())
  assetId                String
  fiscalYear             String
  periodNumber           Int
  depreciationAmount     Float
  accumulatedDepreciation Float
  bookValueAfter         Float
  journalEntryId         String?
  postedAt               DateTime @default(now())

  asset FixedAsset @relation(fields: [assetId], references: [id])

  @@unique([assetId, fiscalYear, periodNumber])
}

// ─── Budget ───────────────────────────────────────────────────────────────────

model BudgetPlan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  fiscalYear   String   // e.g., FY2026
  status       String   @default("draft") // draft | active | closed
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entries BudgetEntry[]
}

model BudgetEntry {
  id           String   @id @default(cuid())
  budgetPlanId String
  accountId    String
  periodNumber Int?     // null = annual budget
  budgetAmount Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())

  budgetPlan BudgetPlan @relation(fields: [budgetPlanId], references: [id], onDelete: Cascade)
  account    Account    @relation(fields: [accountId], references: [id])

  @@unique([budgetPlanId, accountId, periodNumber])
}

// ─── Tax Management ───────────────────────────────────────────────────────────

model TaxCode {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  rate          Float    // percentage e.g. 8.25
  taxType       String   @default("sales") // sales | use | vat | exempt | withholding
  glAccountId   String?
  isActive      Boolean  @default(true)
  description   String?
  createdAt     DateTime @default(now())

  glAccount    Account?         @relation(fields: [glAccountId], references: [id])
  transactions TaxTransaction[]
}

model TaxTransaction {
  id             String   @id @default(cuid())
  taxCodeId      String
  sourceType     String   // order | vendor_invoice | customer_invoice | manual
  sourceId       String
  taxableAmount  Float
  taxAmount      Float
  taxDate        DateTime @default(now())
  fiscalYear     String?
  periodNumber   Int?

  taxCode TaxCode @relation(fields: [taxCodeId], references: [id])
}

// ─── Payroll ──────────────────────────────────────────────────────────────────

model PayrollPeriod {
  id          String   @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  payDate     DateTime
  status      String   @default("open") // open | processing | posted | closed
  fiscalYear  String?
  createdAt   DateTime @default(now())

  entries PayrollEntry[]
}

model PayrollEntry {
  id              String   @id @default(cuid())
  periodId        String
  employeeId      String
  regularHours    Float    @default(0)
  overtimeHours   Float    @default(0)
  hourlyRate      Float
  grossPay        Float
  federalTax      Float    @default(0)
  stateTax        Float    @default(0)
  socialSecurity  Float    @default(0)
  medicare        Float    @default(0)
  otherDeductions Float    @default(0)
  netPay          Float
  status          String   @default("draft") // draft | approved | paid
  journalEntryId  String?
  createdAt       DateTime @default(now())

  period   PayrollPeriod @relation(fields: [periodId], references: [id])
  employee Employee      @relation(fields: [employeeId], references: [id])
}

// ─── Cost Accounting ──────────────────────────────────────────────────────────

model CostCenter {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  type        String   @default("department") // department | project | region | product_line
  managerId   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  allocations CostAllocation[]
  entries     CostLedgerEntry[]
  budgets     CostBudget[]
}

model CostCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  type        String   @default("overhead") // personnel | overhead | materials | services | capex
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  entries     CostLedgerEntry[]
  budgets     CostBudget[]
}

model CostAllocation {
  id           String  @id @default(cuid())
  costCenterId String
  accountId    String?
  percentage   Float
  description  String?
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())

  costCenter CostCenter @relation(fields: [costCenterId], references: [id])
}

model CostLedgerEntry {
  id             String   @id @default(cuid())
  costCenterId   String
  costCategoryId String
  amount         Float
  description    String?
  sourceType     String   @default("manual") // manual | journal | payroll | fixed_asset | allocation
  sourceId       String?
  fiscalYear     String?
  periodNumber   Int?
  entryDate      DateTime @default(now())
  createdAt      DateTime @default(now())

  costCenter   CostCenter   @relation(fields: [costCenterId], references: [id])
  costCategory CostCategory @relation(fields: [costCategoryId], references: [id])
}

model CostBudget {
  id             String  @id @default(cuid())
  costCenterId   String
  costCategoryId String
  fiscalYear     String
  periodNumber   Int?
  budgetAmount   Float

  costCenter   CostCenter   @relation(fields: [costCenterId], references: [id])
  costCategory CostCategory @relation(fields: [costCategoryId], references: [id])

  @@unique([costCenterId, costCategoryId, fiscalYear, periodNumber])
}

// ─── Field Service Extensions ─────────────────────────────────────────────────

model WorkOrderLine {
  id          String  @id @default(cuid())
  workOrderId String
  lineType    String  @default("labor") // labor | part | expense
  description String
  quantity    Float   @default(1)
  unitCost    Float   @default(0)
  totalCost   Float   @default(0)
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

// ─── Purchasing Extensions ────────────────────────────────────────────────────

model PurchaseReceipt {
  id              String   @id @default(cuid())
  receiptNumber   String   @unique
  purchaseOrderId String
  receivedBy      String?
  receivedAt      DateTime @default(now())
  notes           String?

  purchaseOrder PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id])
  lines         PurchaseReceiptLine[]
}

model PurchaseReceiptLine {
  id              String @id @default(cuid())
  receiptId       String
  poItemId        String
  quantityReceived Float

  receipt PurchaseReceipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  poItem  PurchaseOrderItem @relation(fields: [poItemId], references: [id])
}

// ─── Marketing Extensions ─────────────────────────────────────────────────────

model CampaignContact {
  id           String    @id @default(cuid())
  campaignId   String
  customerId   String
  status       String    @default("pending") // pending | sent | opened | clicked | unsubscribed
  sentAt       DateTime?
  openedAt     DateTime?
  createdAt    DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([campaignId, customerId])
}

// ─── Approval Workflows ───────────────────────────────────────────────────────

model ApprovalWorkflow {
  id          String   @id @default(cuid())
  name        String
  entityType  String   // PURCHASE_ORDER | VENDOR_INVOICE | SALES_ORDER | JOURNAL_ENTRY | BUDGET | CUSTOMER
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  steps    ApprovalStep[]
  requests ApprovalRequest[]
}

model ApprovalStep {
  id           String  @id @default(cuid())
  workflowId   String
  stepOrder    Int
  approverRole String  // admin | manager | accountant
  approverName String?
  isRequired   Boolean @default(true)

  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model ApprovalRequest {
  id          String   @id @default(cuid())
  workflowId  String
  entityType  String
  entityId    String
  entityRef   String
  requestedBy String
  currentStep Int      @default(1)
  status      String   @default("pending") // pending | approved | rejected | cancelled
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  actions  ApprovalAction[]
}

model ApprovalAction {
  id        String   @id @default(cuid())
  requestId String
  stepOrder Int
  action    String   // approve | reject | comment
  actorName String
  actorRole String
  comment   String?
  createdAt DateTime @default(now())

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

// ─── CRM / Sales Opportunities ────────────────────────────────────────────────

model Contact {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  email      String?
  phone      String?
  company    String?
  title      String?
  customerId String?
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer      Customer?     @relation(fields: [customerId], references: [id])
  opportunities Opportunity[]
}

model SalesCycle {
  id   String @id @default(cuid())
  name String

  stages        SalesCycleStage[]
  opportunities Opportunity[]
}

model SalesCycleStage {
  id          String  @id @default(cuid())
  cycleId     String
  name        String
  stageOrder  Int
  probability Float   @default(0)

  cycle SalesCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
}

model Opportunity {
  id                String    @id @default(cuid())
  title             String
  contactId         String?
  customerId        String?
  salesCycleId      String?
  currentStageId    String?
  estimatedValue    Float     @default(0)
  probability       Float     @default(0)
  expectedCloseDate DateTime?
  status            String    @default("open") // open | won | lost | cancelled
  assignedTo        String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  contact    Contact?    @relation(fields: [contactId], references: [id])
  customer   Customer?   @relation(fields: [customerId], references: [id])
  salesCycle SalesCycle? @relation(fields: [salesCycleId], references: [id])
}

// ─── Deferrals ────────────────────────────────────────────────────────────────

model DeferralTemplate {
  id                String    @id @default(cuid())
  name              String
  deferralType      String    // REVENUE | EXPENSE
  method            String    // STRAIGHT_LINE | EQUAL_PER_PERIOD | USER_DEFINED
  periodsCount      Int       @default(12)
  startDate         DateTime?
  glAccountId       String?
  deferralAccountId String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())

  schedules DeferralSchedule[]
}

model DeferralSchedule {
  id            String   @id @default(cuid())
  templateId    String
  entityType    String   // INVOICE | JOURNAL
  entityId      String
  entityRef     String
  totalAmount   Float
  deferredAmt   Float
  recognizedAmt Float    @default(0)
  status        String   @default("active") // active | completed | cancelled
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())

  template DeferralTemplate @relation(fields: [templateId], references: [id])
  lines    DeferralLine[]
}

model DeferralLine {
  id         String    @id @default(cuid())
  scheduleId String
  periodDate DateTime
  amount     Float
  isPosted   Boolean   @default(false)
  postedAt   DateTime?

  schedule DeferralSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

// ─── Multi-Currency ───────────────────────────────────────────────────────────

model Currency {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  symbol        String
  isBase        Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  exchangeRates CurrencyRate[]
}

model CurrencyRate {
  id         String   @id @default(cuid())
  currencyId String
  rate       Float
  rateDate   DateTime @default(now())
  source     String   @default("manual") // manual | auto

  currency Currency @relation(fields: [currencyId], references: [id])

  @@index([currencyId, rateDate])
}

// ─── Gift Cards ───────────────────────────────────────────────────────────────

model GiftCard {
  id             String   @id @default(cuid())
  cardNumber     String   @unique
  initialValue   Float
  currentBalance Float
  isActive       Boolean  @default(true)
  customerId     String?
  issuedAt       DateTime @default(now())
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer     Customer?            @relation(fields: [customerId], references: [id])
  transactions GiftCardTransaction[]
}

model GiftCardTransaction {
  id            String   @id @default(cuid())
  giftCardId    String
  type          String   // ISSUE | REDEEM | RELOAD | VOID | CASHOUT
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  reference     String?
  createdAt     DateTime @default(now())

  giftCard GiftCard @relation(fields: [giftCardId], references: [id])
}

// ─── Shipping Methods ─────────────────────────────────────────────────────────

model ShippingMethod {
  id              String   @id @default(cuid())
  name            String
  code            String   @unique
  carrier         String?  // UPS | FEDEX | USPS | LOCAL
  serviceType     String?
  baseRate        Float    @default(0)
  perLbRate       Float    @default(0)
  freeThreshold   Float?
  estimatedDays   Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Fraud Protection ─────────────────────────────────────────────────────────

model FraudRule {
  id        String   @id @default(cuid())
  name      String
  ruleType  String   // ORDER_AMOUNT | VELOCITY | IP_BLOCK | PAYMENT_METHOD
  threshold Float?
  action    String   @default("flag") // flag | block | review
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  alerts FraudAlert[]
}

model FraudAlert {
  id         String   @id @default(cuid())
  ruleId     String?
  entityType String   // ORDER | CUSTOMER | PAYMENT
  entityId   String
  reason     String
  severity   String   @default("medium") // low | medium | high | critical
  status     String   @default("open")   // open | reviewed | dismissed | confirmed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  rule FraudRule? @relation(fields: [ruleId], references: [id])
}

// ─── Store Task Management ────────────────────────────────────────────────────

model TaskList {
  id          String   @id @default(cuid())
  name        String
  description String?
  storeId     String?
  dueDate     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store Store?      @relation(fields: [storeId], references: [id])
  tasks StoreTask[]
}

model StoreTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  storeId     String?
  assignedTo  String?
  dueDate     DateTime?
  priority    String   @default("medium") // low | medium | high | critical
  status      String   @default("pending") // pending | in_progress | completed | cancelled
  taskListId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store    Store?    @relation(fields: [storeId], references: [id])
  taskList TaskList? @relation(fields: [taskListId], references: [id])
}
